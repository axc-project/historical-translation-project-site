---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---
<BaseLayout title="Contact • Historical Translation Project™">
  <Header />
  <main class="mx-auto max-w-6xl px-4 py-14">
    <div class="max-w-3xl">
      <div class="kicker">Contact</div>
      <h1 class="mt-3 h-serif text-4xl sm:text-5xl">Reach out</h1>
      <p class="mt-6 text-ink-900/70 leading-relaxed text-lg">
        For physician dossiers, sourcing notes, research collaboration, or distribution discussions:
      </p>
      <div class="mt-8 card p-8">
        <div class="h-serif text-2xl">Email</div>
        <p class="mt-2 text-ink-900/70">info@axellaresearch.com</p>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
