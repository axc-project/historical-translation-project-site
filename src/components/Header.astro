---
const nav = [
  { href: '/', label: 'Home' },
  { href: '/book', label: 'The Book' },
  { href: '/research', label: 'Research Library' },
  { href: '/supplements', label: 'Supplements' },
  { href: '/method', label: 'Our Method' },
  { href: '/faq', label: 'FAQ' },
  { href: '/contact', label: 'Contact' },
];
---
<header style="position:sticky;top:0;z-index:50;backdrop-filter:saturate(140%) blur(10px);background:rgba(251,247,239,.78);border-bottom:1px solid rgba(11,18,32,.10)">
  <div class="container" style="display:flex;align-items:center;justify-content:space-between;padding:14px 20px;gap:14px">
    <a href="/" style="text-decoration:none;display:flex;align-items:center;gap:10px">
      <span aria-hidden="true" style="width:12px;height:12px;border-radius:3px;background:linear-gradient(180deg,var(--gold2),var(--gold));display:inline-block"></span>
      <span style="font-weight:800;color:var(--navy);letter-spacing:.02em">Historical Translation Project™</span>
    </a>

    <nav aria-label="Primary" style="display:none;gap:14px;align-items:center" class="nav">
      {nav.map(item => (
        <a href={item.href} style="text-decoration:none;color:rgba(11,27,58,.88);font-weight:650;font-size:.95rem">{item.label}</a>
      ))}
    </nav>

    <div style="display:flex;gap:10px;align-items:center">
      <a class="btn ghost" href="/supplements">View Supplements</a>
      <a class="btn" href="/research">Download Dossiers</a>
    </div>
  </div>

  <style>
    @media (min-width: 980px){
      .nav{display:flex !important}
    }
  </style>
</header>
