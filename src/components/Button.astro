---
const {
  href = "#",
  variant = "primary", // primary | secondary | ghost
  class: className = ""
} = Astro.props;

const base =
  "inline-flex items-center justify-center rounded-xl2 px-5 py-3 text-sm tracking-wide transition-all duration-200 select-none";
const styles = {
  primary:
    "bg-gold-500 text-navy-900 shadow-soft hover:shadow-glow hover:-translate-y-[1px]",
  secondary:
    "bg-navy-800/60 text-white border border-gold-500/20 hover:border-gold-500/35 hover:bg-navy-750/70",
  ghost:
    "text-white/85 hover:text-white border border-white/10 hover:border-gold-500/25 bg-white/0 hover:bg-white/5"
};
---
<a href={href} class={`${base} ${styles[variant]} ${className}`}>
  <slot />
</a>
