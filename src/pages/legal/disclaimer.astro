---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Disclaimers" description="Educational content only; not medical advice. FDA disclaimer for structure/function statements.">
  <section class="card" style="padding:22px">
    <div class="kicker">Legal</div>
    <h1 class="h1">Disclaimers</h1>

    <div class="hr"></div>

    <h2 class="h2">Educational content</h2>
    <p class="small">
      The content on this website is for educational purposes only and is not medical advice. It does not establish a clinician–patient relationship.
    </p>

    <h2 class="h2" style="margin-top:14px">Dietary supplement disclaimer</h2>
    <p class="small">
      Statements on this website regarding dietary supplements are intended to describe general structure/function support. They are not intended to diagnose, treat, cure, or prevent any disease.
    </p>

    <h2 class="h2" style="margin-top:14px">FDA disclaimer</h2>
    <p class="small">
      These statements have not been evaluated by the Food and Drug Administration. This product is not intended to diagnose, treat, cure, or prevent any disease.
    </p>
  </section>
</BaseLayout>
