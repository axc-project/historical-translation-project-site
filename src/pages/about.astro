---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---
<BaseLayout title="About • Historical Translation Project™">
  <Header />
  <main class="mx-auto max-w-6xl px-4 py-14">
    <div class="max-w-3xl">
      <div class="kicker">About</div>
      <h1 class="mt-3 h-serif text-4xl sm:text-5xl">A long-term translation institute</h1>
      <p class="mt-6 text-ink-900/70 leading-relaxed text-lg">
        Historical Translation Project™ is a research-driven initiative translating classical medical traditions into structured modern frameworks—
        through publications, educational dossiers, and curated botanical formulations.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      <div class="card p-8">
        <div class="h-serif text-2xl">Mission</div>
        <p class="mt-3 text-ink-900/70 leading-relaxed">
          Preserve and translate historically grounded health principles across civilizations—then responsibly integrate them with modern evidence.
        </p>
      </div>
      <div class="card p-8">
        <div class="h-serif text-2xl">Clinical posture</div>
        <p class="mt-3 text-ink-900/70 leading-relaxed">
          We do not provide medical advice. Our goal is to educate physicians and patients and support clinician-directed use with clean, transparent dossiers.
        </p>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
