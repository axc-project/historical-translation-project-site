---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import Button from "@components/Button.astro";
import Card from "@components/Card.astro";
import SectionHeading from "@components/SectionHeading.astro";
import { formulas } from "@data/formulas";
import { books } from "@data/books";

const heroImage = "/images/hero-landscape.jpg"; // upload this
---
<BaseLayout
  title="Historical Translation Project™"
  description="Research-driven botanical frameworks rooted in historical texts and aligned with contemporary safety standards."
>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img src={heroImage} alt="" class="h-full w-full object-cover opacity-55" />
      <div class="absolute inset-0 bg-gradient-to-b from-navy-900/75 via-navy-900/70 to-navy-900"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_10%,rgba(212,175,55,0.16),transparent_45%)]"></div>
    </div>

    <Container class="relative py-14 sm:py-20 md:py-24">
      <div class="max-w-3xl">
        <div class="text-[12px] uppercase tracking-[0.28em] text-white/75">
          Historical Translation Project™
        </div>
        <h1 class="mt-5 font-serif text-4xl sm:text-5xl tracking-tight text-white">
          Translating Classical Medicine Into Structured Modern Systems
        </h1>
        <p class="mt-6 text-white/78 leading-relaxed text-base sm:text-lg">
          Research-driven botanical frameworks rooted in historical texts and aligned with contemporary safety standards.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <Button href="/formulations" variant="primary">Explore Formulations</Button>
          <Button href="/publications" variant="secondary">View Publications</Button>
        </div>
      </div>
    </Container>
  </section>

  <section class="mt-16">
    <Container>
      <SectionHeading
        title="Formulations"
        lede="A modular architecture: foundational cores first, with optional add-ons only when additional support is desired.*"
      />

      <div class="grid gap-6 md:grid-cols-2">
        {formulas.map((f) => (
          <Card class="p-7">
            <div class="flex items-start justify-between gap-6">
              <div>
                <div class="text-[11px] uppercase tracking-[0.22em] text-gold-450/90">
                  {f.category}
                </div>
                <h3 class="mt-3 font-serif text-2xl text-white">{f.name}</h3>
                <p class="mt-3 text-white/75 leading-relaxed">{f.heroTagline}</p>
              </div>

              <div class="hidden sm:block shrink-0">
                <div class="h-14 w-14 rounded-2xl border border-gold-500/20 bg-white/5 flex items-center justify-center">
                  <span class="text-gold-500 text-xl">✦</span>
                </div>
              </div>
            </div>

            <div class="mt-6 flex flex-wrap gap-3">
              <Button href={`/formulations/${f.slug}`} variant="secondary">View Program</Button>
              <a
                href="/contact"
                class="inline-flex items-center text-sm text-white/70 hover:text-white underline decoration-white/20 hover:decoration-gold-500/40 underline-offset-4"
              >
                Request research notes
              </a>
            </div>
          </Card>
        ))}
      </div>
    </Container>
  </section>

  <section class="mt-20">
    <Container>
      <SectionHeading title="Our Method" />

      <Card class="p-8">
        <div class="prose-ish space-y-4">
          <p>
            The Historical Translation Project™ conducts structured research into classical medical traditions and translates enduring principles into modern biological frameworks.
          </p>
          <p>
            Our formulations bridge time-tested medical doctrine with contemporary scientific literature. By integrating historically validated practices with current data and physiological insight, we develop targeted support supplements designed within a disciplined, modular architecture.*
          </p>
          <p>
            Rather than replicate folklore or chase trends, we evaluate traditional formulations through modern scientific lenses—prioritizing pathway relevance, extract standardization, and responsible safety guidance.
          </p>
        </div>

        <div class="mt-8 grid gap-4 md:grid-cols-2">
          {[
            "Historical doctrine → modern biological translation",
            "Textual analysis integrated with contemporary peer-reviewed literature",
            "Structured formulation design rooted in pathway-level understanding",
            "Modular stacking architecture to prevent redundancy",
            "Scalable framework supporting future publications and formulations"
          ].map((item) => (
            <div class="flex gap-3 rounded-xl2 border border-white/10 bg-white/5 p-4">
              <div class="mt-1 h-2 w-2 rounded-full bg-gold-500"></div>
              <div class="text-white/75 leading-relaxed">{item}</div>
            </div>
          ))}
        </div>
      </Card>
    </Container>
  </section>

  <section class="mt-20">
    <Container>
      <SectionHeading
        title="Publications"
        lede="Our research begins with texts. Each publication becomes a foundation for responsible translation into structured modern systems."
      />

      <div class="grid gap-6 md:grid-cols-2">
        {books.map((b) => (
          <Card class="p-7">
            <div class="flex gap-6">
              <div class="shrink-0 w-20">
                <div class="aspect-[2/3] rounded-xl2 overflow-hidden border border-gold-500/15 bg-white/5">
                  <img src={b.coverImage ?? ""} alt={b.title} class="h-full w-full object-cover" />
                </div>
              </div>
              <div>
                <h3 class="font-serif text-2xl text-white">{b.title}</h3>
                <div class="mt-2 text-white/70">{b.subtitle}</div>
                <p class="mt-4 text-white/75 leading-relaxed">{b.description}</p>

                <div class="mt-6">
                  <Button href="/publications" variant="secondary">View Publications</Button>
                </div>
              </div>
            </div>
          </Card>
        ))}
      </div>
    </Container>
  </section>

  <section class="mt-20">
    <Container>
      <Card class="p-10 text-center">
        <div class="text-[12px] uppercase tracking-[0.28em] text-white/70">Ongoing Research</div>
        <h2 class="mt-4 font-serif text-3xl text-white">Expanding Translational Programs</h2>
        <p class="mt-4 mx-auto max-w-2xl text-white/75 leading-relaxed">
          Expanding beyond Mediterranean systems into additional classical medical traditions and their modern interpretations.
        </p>
        <div class="mt-8 flex justify-center">
          <Button href="/contact" variant="primary">Contact</Button>
        </div>
      </Card>
    </Container>
  </section>
</BaseLayout>
