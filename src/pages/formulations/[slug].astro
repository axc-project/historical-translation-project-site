---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/Button.astro";
import { formulations } from "../../data/formulations.js";

// ✅ Required for static builds on Vercel
export function getStaticPaths() {
  return formulations.map((f) => ({
    params: { slug: f.slug },
    props: { formulation: f },
  }));
}

const { formulation } = Astro.props;

// If someone navigates to an unknown slug (shouldn't happen in static build)
if (!formulation) {
  throw new Error("Formulation not found");
}
---

<BaseLayout title={`${formulation.name} — Historical Translation Project™`} description={formulation.subtitle}>
  <section class="section">
    <div class="container-xl">
      <div class="badge">Core Formula</div>
      <h1 class="h1 mt-4 text-4xl md:text-5xl">{formulation.name}</h1>
      <p class="sub mt-4">{formulation.subtitle}</p>

      <div class="mt-8 grid lg:grid-cols-12 gap-8">
        <div class="lg:col-span-8">
          <div class="card-solid soft-shadow p-7">
            <h2 class="font-serif text-2xl text-navy">Overview</h2>
            <p class="mt-3 text-muted leading-relaxed">{formulation.description}</p>

            {formulation.bullets?.length ? (
              <div class="mt-6">
                <h3 class="font-semibold text-navy">Structure/Function Support*</h3>
                <ul class="mt-3 list-disc pl-5 text-muted space-y-2">
                  {formulation.bullets.map((b) => <li>{b}</li>)}
                </ul>
              </div>
            ) : null}

            {formulation.ingredients?.length ? (
              <div class="mt-8">
                <h3 class="font-semibold text-navy">Formula (in development)</h3>
                <div class="mt-3 overflow-hidden rounded-2xl border border-[rgba(11,15,20,0.10)]">
                  <table class="w-full text-sm">
                    <thead class="bg-[rgba(7,22,37,0.06)]">
                      <tr>
                        <th class="text-left p-3">Ingredient</th>
                        <th class="text-left p-3">Amount</th>
                      </tr>
                    </thead>
                    <tbody>
                      {formulation.ingredients.map((ing) => (
                        <tr class="border-t border-[rgba(11,15,20,0.10)]">
                          <td class="p-3">{ing.name}</td>
                          <td class="p-3">{ing.amount}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            ) : null}

            <p class="mt-6 text-xs text-muted">
              *Educational structure/function statements only. Not medical advice. Supplements are not intended to diagnose,
              treat, cure, or prevent disease.
            </p>
          </div>
        </div>

        <aside class="lg:col-span-4">
          <div class="card-solid soft-shadow p-6">
            <h3 class="font-semibold text-navy">Next steps</h3>
            <p class="mt-2 text-sm text-muted">
              This product is in development. Purchase links will go live once manufacturing and Shopify checkout are ready.
            </p>

            <div class="mt-5 flex flex-col gap-3">
              <Button href="/shop" variant="gold" text="Purchase (Coming Soon)" />
              <Button href="/stacking" variant="navy" text="How to Stack" />
              <Button href="/evidence" variant="ghost" text="Evidence & Safety" />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
