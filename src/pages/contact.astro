---
import Base from "../layouts/Base.astro";
import { SITE } from "../data/site";
---
<Base title="Contact — Historical Translation Project™">
  <section class="mx-auto max-w-6xl px-5 py-14 sm:py-20">
    <div class="max-w-2xl">
      <div class="font-display text-4xl sm:text-5xl text-ink">Contact</div>
      <p class="mt-5 text-xl text-ink/75 leading-relaxed">
        For research collaborations, publication inquiries, or product updates.
      </p>

      <div class="mt-10 rounded-2xl bg-white/70 ring-1 ring-black/5 shadow-card p-8">
        <div class="font-display text-2xl">Email</div>
        <p class="mt-3 text-lg text-ink/75">
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </p>

        <div class="mt-8 font-display text-2xl">Updates</div>
        <p class="mt-3 text-lg text-ink/75">
          Until Shopify is enabled, this opens your email client with a prefilled request.
        </p>
        <a class="mt-4 inline-flex no-underline hover:no-underline rounded-md bg-gold text-ink font-semibold px-6 py-3 hover:bg-gold2 transition"
           href={`mailto:${SITE.email}?subject=HTP%20Updates&body=Please%20add%20me%20to%20the%20HTP%20updates%20list.`}>
          Request updates
        </a>
      </div>
    </div>
  </section>
</Base>
