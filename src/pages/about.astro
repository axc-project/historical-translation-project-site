---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import Card from "@components/Card.astro";
import SectionHeading from "@components/SectionHeading.astro";
---
<BaseLayout title="About — Historical Translation Project™">
  <Container class="pt-14">
    <SectionHeading
      title="About"
      lede="The Historical Translation Project™ researches ancient remedies across global history and translates enduring principles into modern, responsible wellness education and botanical formulation architecture."
    />

    <div class="grid gap-6 lg:grid-cols-2">
      <Card class="p-8">
        <h2 class="font-serif text-2xl text-white">Mission</h2>
        <ul class="mt-6 space-y-3">
          {[
            "Continue researching classical medical traditions",
            "Translate doctrine into modern biological systems",
            "Publish structured educational works",
            "Maintain scalable formulation framework"
          ].map((item) => (
            <li class="flex gap-3">
              <span class="mt-[10px] h-2 w-2 rounded-full bg-gold-500"></span>
              <span class="text-white/78 leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
      </Card>

      <Card class="p-8">
        <h2 class="font-serif text-2xl text-white">Institutional Standards</h2>
        <div class="mt-5 prose-ish space-y-4">
          <p>
            The Historical Translation Project™ is built as a publication-first initiative: texts come before products. We translate
            classical doctrine into modern language, then evaluate which elements are compatible with contemporary safety expectations.
          </p>
          <p>
            Our formulation work uses standardized extracts when possible, avoids redundant stacking, and keeps claims within
            responsible dietary supplement boundaries.*
          </p>
          <p>
            We publish sources and provide dossier-style summaries so readers can understand historical context, modern evidence,
            and practical use considerations.
          </p>
        </div>
      </Card>
    </div>
  </Container>
</BaseLayout>
