---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
---
<BaseLayout title="Rambam’s Guide to Health • Historical Translation Project™">
  <section class="mx-auto max-w-6xl px-4 pt-10 pb-16">
    <div class="grid lg:grid-cols-12 gap-10 items-start">
      <div class="lg:col-span-7">
        <div class="text-xs font-semibold tracking-widest text-gold">BOOK</div>
        <h1 class="mt-2 font-serif text-4xl md:text-5xl text-navy">Rambam’s Guide to Health</h1>
        <p class="mt-3 text-muted text-lg leading-relaxed max-w-2xl">
          A Practical Modern Interpretation of Medieval Preventive Medicine — the inaugural publication of the Historical Translation Project™.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <Button href="https://www.amazon.com/dp/B0GPNWH877" variant="gold" text="Purchase on Amazon" external={true} />
          <Button href="/projects/rambam" variant="secondary" text="Read about Project 01" />
        </div>
        <div class="mt-8 rounded-xl2 bg-card shadow-soft border border-line p-6">
          <div class="text-xs font-semibold tracking-widest text-gold">ABOUT THIS EDITION</div>
          <p class="mt-3 text-sm text-muted leading-relaxed">
            This book establishes the method: extract primary-source preventive principles, translate historical terms in context, and map them to modern understanding—without medical advice and without disease claims.
          </p>
          <p class="mt-3 text-xs text-muted">Educational content only; not medical advice.</p>
        </div>
      </div>

      <div class="lg:col-span-5">
        <div class="rounded-xl2 bg-card shadow-glow border border-line overflow-hidden">
          <img src="/images/book-cover.jpg" alt="Rambam’s Guide to Health cover" class="w-full h-auto" loading="lazy" />
          <div class="p-6">
            <div class="text-sm font-semibold text-navy">Quick highlights</div>
            <ul class="mt-3 list-disc pl-5 space-y-2 text-sm text-muted">
              <li>Digestion as foundation</li>
              <li>Rhythm and moderation</li>
              <li>Mediterranean diet logic</li>
              <li>Modern interpretation and context</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
