---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'The Book — Rambam’s Guide to Health';
const description = 'Rambam’s Guide to Health: a practical modern interpretation of medieval preventive medicine, presented under the Historical Translation Project™.';
---
<BaseLayout title={title} description={description} canonical="/book">
  <section class="bg-parchment-50">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <div class="grid gap-10 lg:grid-cols-12 lg:items-start">
        <div class="lg:col-span-5">
          <div class="rounded-3xl bg-navy-950 overflow-hidden shadow-soft border border-white/10">
            <img src="/images/rambam-bookcover.jpg" alt="Rambam’s Guide to Health cover" class="w-full h-auto" loading="eager" />
          </div>
        </div>
        <div class="lg:col-span-7">
          <div class="inline-flex items-center gap-2 rounded-full border border-slate-900/10 bg-white/70 px-4 py-2 text-xs text-slate-700 shadow-soft">Publication</div>
          <h1 class="mt-6 text-4xl sm:text-5xl text-navy-950">Rambam’s Guide to Health</h1>
          <p class="mt-3 text-lg text-slate-700">A practical modern interpretation of medieval preventive medicine.</p>

          <div class="mt-5 space-y-3 text-slate-700 prose-htp">
            <p>
              This book distills timeless preventive principles—habit, routine, diet, movement, sleep, and temperament—through a modern lens.
              It is written for general wellness audiences and focuses on education, not diagnosis or medical claims.
            </p>
            <p>
              The Historical Translation Project™ connects this work to companion dossiers and formulation pages, so readers can explore
              both historical context and modern evidence signals in one cohesive system.
            </p>
          </div>

          <div class="mt-7 flex flex-col sm:flex-row gap-3">
            <a class="btn-gold inline-flex items-center justify-center rounded-full bg-gold-400 px-6 py-3 text-sm font-semibold text-navy-950 shadow-glow hover:bg-gold-200 transition" href="https://www.amazon.com/dp/B0GPNWH877" target="_blank" rel="noreferrer">Buy on Amazon</a>
            <a class="inline-flex items-center justify-center rounded-full border border-navy-950/15 bg-white/70 px-6 py-3 text-sm font-semibold text-navy-950 hover:bg-white" href="/research-library">Browse related research</a>
          </div>

          <div class="mt-10 grid gap-4 sm:grid-cols-2">
            <div class="rounded-2xl border border-slate-200 bg-white/70 p-6">
              <div class="font-semibold text-navy-950">What you’ll learn</div>
              <ul class="mt-3 space-y-2 text-sm text-slate-700">
                <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-gold-400"></span><span>Core preventive principles, simplified</span></li>
                <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-gold-400"></span><span>How routines shape long-term wellness</span></li>
                <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-gold-400"></span><span>Food, digestion, and moderation themes</span></li>
                <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-gold-400"></span><span>Movement, sleep, and recovery habits</span></li>
              </ul>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-white/70 p-6">
              <div class="font-semibold text-navy-950">How we keep it responsible</div>
              <ul class="mt-3 space-y-2 text-sm text-slate-700">
                <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-navy-950"></span><span>Educational framing (no medical advice)</span></li>
                <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-navy-950"></span><span>Clear sourcing and citations in dossiers</span></li>
                <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-navy-950"></span><span>Compliant structure/function language</span></li>
                <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-navy-950"></span><span>Optional add-ons only when additive</span></li>
              </ul>
            </div>
          </div>

          <p class="mt-6 text-xs text-slate-600">Amazon availability may change. Kindle and paperback options vary by region.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
