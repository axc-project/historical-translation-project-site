---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import Button from "@components/Button.astro";
import Card from "@components/Card.astro";
import SectionHeading from "@components/SectionHeading.astro";
import { formulas } from "@data/formulas";
import { books } from "@data/books";

const heroImage = "/images/hero-landscape.png"; // included; replace as desired
---
<BaseLayout
  title="Historical Translation Project™"
  description="Research-driven botanical frameworks rooted in historical texts and aligned with contemporary safety standards."
>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div
        class="h-full w-full"
        style={`background-image:url(${heroImage}); background-size:cover; background-position:center; opacity:0.80;`}
      ></div>

      <!-- Use the CSS-defined overlay (readable but not overly dark) -->
      <div class="absolute inset-0 heroOverlay"></div>

      <!-- subtle gold glow -->
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_10%,rgba(212,175,55,0.22),transparent_45%)]"></div>
    </div>

    <Container class="relative py-14 sm:py-20 md:py-24 pointer-events-auto">
      <div class="max-w-3xl">
        <div class="text-[12px] uppercase tracking-[0.28em] text-white/70">
          Historical Translation Project™
        </div>

        <!-- Force HERO heading to white -->
        <h1 class="mt-5 font-serif text-4xl sm:text-5xl tracking-tight text-white">
          Translating Classical Medicine Into Structured Modern Systems
        </h1>

        <!-- Force HERO paragraph to white -->
        <p class="mt-6 text-white/80 leading-relaxed text-base sm:text-lg">
          Research-driven botanical frameworks rooted in historical texts and aligned with contemporary safety standards.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <Button href="/formulations" variant="primary">Explore Formulations</Button>
          <Button href="/publications" variant="secondary">View Publications</Button>
        </div>
      </div>
    </Container>

    <!-- cream fade into parchment sections -->
    <div class="pointer-events-none absolute inset-x-0 bottom-0 h-40 bg-gradient-to-b from-transparent via-[rgba(246,241,230,.65)] to-[rgb(246,241,230)]"></div>
  </section>

  <section class="mt-16">
    <Container>
      <SectionHeading
        title="Formulations"
        lede="A modular architecture: foundational cores first, with optional add-ons only when additional support is desired.*"
      />

      <div class="grid gap-6 md:grid-cols-2">
        {formulas.map((f) => (
          <Card class="p-7">
            <div class="flex items-start justify-between gap-6">
              <div>
                <div class="text-[11px] uppercase tracking-[0.22em] text-gold-450/90">
                  {f.category}
                </div>
                <h3 class="mt-3 font-serif text-2xl parchment-text">{f.name}</h3>
                <p class="mt-3 parchment-text/75 leading-relaxed">{f.heroTagline}</p>
              </div>

              {f.bottleImage && (
                <div class="hidden sm:block shrink-0">
                  <div class="h-20 w-20 rounded-2xl p-0 bg-transparent border-0 shadow-none">
                    <img
                      src={f.bottleImage}
                      alt=""
                      class="h-full w-full object-contain bottleImg"
                      loading="lazy"
                    />
                  </div>
                </div>
              )}
            </div>

            <div class="mt-6 flex flex-wrap gap-3">
              <Button href={`/formulations/${f.slug}`} variant="secondary">View Program</Button>

              <Button
                href={f.dossierUrl && f.dossierUrl.length ? f.dossierUrl : "#"}
                variant="secondary"
                class={f.dossierUrl && f.dossierUrl.length ? "" : "pointer-events-none opacity-60"}
              >
                Download Dossier
              </Button>

              <Button
                href={f.shopUrl && f.shopUrl.length ? f.shopUrl : "#"}
                variant="primary"
                class={f.shopUrl && f.shopUrl.length ? "" : "pointer-events-none opacity-60"}
              >
                Purchase
              </Button>
            </div>
          </Card>
        ))}
      </div>
    </Container>
  </section>

  <section class="mt-20">
    <Container>
      <SectionHeading
        title="Publications"
        lede="Our research begins with texts. Each publication becomes a foundation for responsible translation into structured modern systems."
      />

      <div class="grid gap-6 md:grid-cols-2">
        {books.map((b) => (
          <Card class="p-7">
            <div class="flex gap-6">
              <div class="shrink-0 w-20">
                <div class="aspect-[2/3] rounded-xl2 overflow-hidden border border-gold-500/15 bg-white/5">
                  <img src={b.coverImage ?? ""} alt={b.title} class="h-full w-full object-cover" />
                </div>
              </div>

              <div>
                <h3 class="font-serif text-2xl parchment-text">{b.title}</h3>
                <div class="mt-2 parchment-text/70">{b.subtitle}</div>
                <p class="mt-4 parchment-text/75 leading-relaxed">{b.description}</p>

                <div class="mt-6">
                  <div class="flex flex-wrap gap-3">
                    <Button href="/publications" variant="secondary">View Publications</Button>

                    <Button
                      href={b.amazonUrl && b.amazonUrl.length ? b.amazonUrl : "#"}
                      variant="primary"
                      class={b.amazonUrl && b.amazonUrl.length ? "" : "pointer-events-none opacity-60"}
                    >
                      Purchase (Amazon)
                    </Button>
                  </div>
                </div>
              </div>
            </div>
          </Card>
        ))}
      </div>
    </Container>
  </section>

  <section class="mt-20">
    <Container>
      <Card class="p-10 text-center">
        <div class="text-[12px] uppercase tracking-[0.28em] parchment-text/70">Ongoing Research</div>
        <h2 class="mt-4 font-serif text-3xl parchment-text">Expanding Translational Programs</h2>
        <p class="mt-4 mx-auto max-w-2xl parchment-text/75 leading-relaxed">
          Expanding beyond Mediterranean systems into additional classical medical traditions and their modern interpretations.
        </p>
        <div class="mt-8 flex justify-center">
          <Button href="/contact" variant="primary">Contact</Button>
        </div>
      </Card>
    </Container>
  </section>
</BaseLayout>
