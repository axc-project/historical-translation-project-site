---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
const email = "info@historicaltranslationproject.com";
const subject = "Notify me — Purchase launch";
const body = `Hello Historical Translation Project™ team,

Please notify me when purchasing is live (Shopify launch).

Name:
Email:
Interested product(s):

Thank you.`;
const mailto = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
---
<BaseLayout title="Shop • Coming Soon • Historical Translation Project™" description="Shopify checkout is coming soon. Join the early access list.">
  <section class="mx-auto max-w-6xl px-4 pt-10 pb-16">
    <div class="text-xs font-semibold tracking-widest text-gold">SHOP</div>
    <h1 class="mt-2 font-serif text-4xl md:text-5xl text-navy">Coming soon</h1>
    <p class="mt-4 text-muted text-lg max-w-3xl leading-relaxed">
      Our Shopify checkout isn’t live yet. We’re finalizing manufacturing, labels, and compliance review.
      If you’d like early access when purchasing opens, join the notify list below.
    </p>

    <div class="mt-10 grid lg:grid-cols-12 gap-6 items-start">
      <div class="lg:col-span-7 rounded-xl2 bg-card shadow-soft border border-line p-6">
        <div class="text-sm font-semibold text-navy">Early access request</div>
        <p class="mt-2 text-sm text-muted leading-relaxed">
          Click the button to email us. You can specify which product(s) you’re interested in.
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <Button href={mailto} variant="gold" text="Notify Me" external={true} />
          <Button href="/formulations" variant="secondary" text="Browse Formulas" />
        </div>

        <div class="mt-6 rounded-xl2 bg-parchment border border-line p-4 text-xs text-muted leading-relaxed">
          <div class="font-semibold text-navy">Important</div>
          Educational content only; not medical advice. Products (when available) are not intended to diagnose, treat, cure, or prevent any disease.
        </div>
      </div>

      <aside class="lg:col-span-5 rounded-xl2 bg-navy text-white border border-navy/10 shadow-soft overflow-hidden">
        <div class="p-6">
          <div class="text-xs font-semibold tracking-widest text-gold">WHAT’S NEXT</div>
          <ul class="mt-3 list-disc pl-5 space-y-2 text-sm text-white/85">
            <li>Finalize formula specs + COA standards</li>
            <li>Manufacturing + stability/identity testing plan</li>
            <li>Label compliance review (structure/function only)</li>
            <li>Shopify setup + checkout launch</li>
          </ul>
          <div class="mt-6 text-xs text-white/70">
            Questions? Email <a class="underline hover:text-gold" href="mailto:info@historicaltranslationproject.com">info@historicaltranslationproject.com</a>
          </div>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
