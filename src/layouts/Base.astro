---
import "../styles/global.css";
import Logo from "../components/Logo.astro";
import Nav from "../components/Nav.astro";
import MobileNav from "../components/MobileNav.astro";

const {
  title = "Historical Translation Project™",
  description = "Research-driven translations of preventive principles from across global medical history into modern, evidence-forward educational dossiers and botanical formulation systems.",
} = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/images/htp-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=EB+Garamond:wght@400;500;600&display=swap" rel="stylesheet">
  </head>
  <body>
    <header class="relative bg-navy bg-grain text-parchment">
      <div class="absolute inset-0 opacity-35 pointer-events-none"
           style="background-image: linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,0));"></div>
      <div class="relative mx-auto max-w-6xl px-5 py-5">
        <div class="flex items-center justify-between gap-4">
          <a href="/" class="no-underline hover:no-underline">
            <Logo size={64} class="scale-[.98] sm:scale-100"/>
          </a>
          <Nav />
        </div>
        <div class="mt-5 hidden lg:block h-px bg-gold/40"></div>
      </div>
      <MobileNav />
    </header>

    <main class="min-h-[60vh] bg-parchment bg-parchment">
      <slot />
    </main>

    <footer class="bg-navy text-parchment">
      <div class="mx-auto max-w-6xl px-5 py-14">
        <div class="grid md:grid-cols-3 gap-10">
          <div>
            <div class="font-display text-xl text-gold2 tracking-wide">Historical Translation Project™</div>
            <p class="mt-3 text-parchment/80 leading-relaxed">
              Translating preventive principles from across global medical history into structured modern education and botanical systems.
            </p>
            <p class="mt-4 text-parchment/70 text-sm">
              Educational content only; not medical advice. Supplements are not intended to diagnose, treat, cure, or prevent disease.
            </p>
          </div>
          <div>
            <div class="text-gold2 font-display tracking-wide">Explore</div>
            <ul class="mt-3 space-y-2 text-parchment/85">
              <li><a href="/research">Research</a></li>
              <li><a href="/publications">Publications</a></li>
              <li><a href="/formulations">Formulations</a></li>
              <li><a href="/method">Method</a></li>
              <li><a href="/about">About</a></li>
              <li><a href="/contact">Contact</a></li>
              <li><a href="/shop">Shop (Coming Soon)</a></li>
            </ul>
          </div>
          <div>
            <div class="text-gold2 font-display tracking-wide">Updates</div>
            <p class="mt-3 text-parchment/85 leading-relaxed">
              Join the list for launch updates, new publications, and new formulations.
            </p>
            <form class="mt-4 flex gap-2" action="mailto:info@axellaresearch.com" method="post" enctype="text/plain">
              <input class="flex-1 rounded-md px-3 py-2 bg-white/10 ring-1 ring-white/15 placeholder:text-white/60"
                     type="email" name="email" placeholder="Email address" required />
              <button class="rounded-md px-4 py-2 bg-gold text-ink font-semibold hover:bg-gold2 transition" type="submit">Notify me</button>
            </form>
            <p class="mt-3 text-xs text-parchment/60">For now this opens your email client. Shopify checkout will be added when enabled.</p>
          </div>
        </div>
        <div class="mt-12 pt-8 border-t border-white/10 text-sm text-parchment/60 flex flex-col sm:flex-row gap-2 justify-between">
          <div>© {new Date().getFullYear()} Historical Translation Project™</div>
          <div>Contact: <a class="text-parchment/80" href="mailto:info@axellaresearch.com">info@axellaresearch.com</a></div>
        </div>
      </div>
    </footer>
  </body>
</html>
