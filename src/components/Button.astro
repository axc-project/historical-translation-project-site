---
const {
  href = "#",
  variant = "primary", // primary | secondary | ghost
  class: className = ""
} = Astro.props;

const base =
  "pressable inline-flex items-center justify-center rounded-xl2 px-5 py-3 text-sm tracking-wide transition-all duration-200 select-none focus:outline-none focus-visible:ring-2 focus-visible:ring-gold-500/40";
const styles = {
  primary:
    "bg-[#d4af37] text-[#071523] font-semibold shadow-soft hover:shadow-glow hover:-translate-y-[1px] hover:brightness-105",
  secondary:
    "bg-[rgba(245,239,228,.75)] text-[#071523] border border-[rgba(7,21,35,.18)] hover:border-gold-500/40 hover:bg-navy-750/80",
  ghost:
    "text-white/85 hover:text-white border border-white/10 hover:border-gold-500/25 bg-white/0 hover:bg-white/5"
};
---
<a href={href} class={`${base} ${styles[variant]} ${className}`}>
  <slot />
</a>
