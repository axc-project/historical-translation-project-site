---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { title = 'Historical Translation Project™', description = 'Historical foundations + modern evidence. Educational dossiers and thoughtfully designed botanical formulations.', canonical = '/' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/images/htp-logo.png" />
    <link rel="canonical" href={new URL(canonical, Astro.site).toString()} />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
