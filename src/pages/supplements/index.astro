---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import products from '../../data/products.json';
---
<BaseLayout title="Supplements" description="Explore formulas designed for routine support. Educational content only; not medical advice.">
  <section class="card" style="padding:22px">
    <div class="kicker">Supplements</div>
    <h1 class="h1">Formulas designed for routine support</h1>
    <p style="max-width:70ch;margin-top:10px;color:rgba(11,18,32,.84)">
      Each formula is paired with a downloadable educational dossier that summarizes historical foundations and modern references. No disease treatment claims.
    </p>
  </section>

  <section class="grid cols-3" style="margin-top:16px">
    {products.map(p => <ProductCard p={p} />)}
  </section>
</BaseLayout>
