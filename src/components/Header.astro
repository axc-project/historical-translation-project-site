---
import Logo from "./Logo.astro";
import Button from "./Button.astro";
---
<header class="sticky top-0 z-50 backdrop-blur bg-parchment/85 border-b border-line">
  <div class="mx-auto max-w-6xl px-4 py-3 flex items-center justify-between gap-4">
    <a href="/" class="shrink-0"><Logo compact={true} /></a>
    <nav class="hidden md:flex items-center gap-6 text-sm text-navy">
      <a class="hover:text-gold transition" href="/formulations">Formulas</a>
      <a class="hover:text-gold transition" href="/book">Book</a>
      <a class="hover:text-gold transition" href="/projects/rambam">Rambam Project</a>
      <a class="hover:text-gold transition" href="/about">About</a>
      <a class="hover:text-gold transition" href="/contact">Contact</a>
      <a class="hover:text-gold transition" href="/shop">Shop</a>
    </nav>
    <div class="hidden md:flex items-center gap-3">
      <Button href="/formulations" variant="secondary" text="Explore" />
      <Button href="/shop" variant="gold" text="Purchase" />
    </div>
    <button id="menuBtn" class="md:hidden inline-flex items-center rounded-xl2 border border-navy/15 bg-white px-3 py-2 text-sm font-semibold text-navy">Menu</button>
  </div>
  <div id="mobileMenu" class="md:hidden hidden border-t border-line bg-parchment">
    <div class="mx-auto max-w-6xl px-4 py-4 grid gap-3 text-sm">
      <a class="text-navy hover:text-gold" href="/formulations">Formulas</a>
      <a class="text-navy hover:text-gold" href="/book">Book</a>
      <a class="text-navy hover:text-gold" href="/projects/rambam">Rambam Project</a>
      <a class="text-navy hover:text-gold" href="/about">About</a>
      <a class="text-navy hover:text-gold" href="/contact">Contact</a>
      <a class="text-navy hover:text-gold" href="/shop">Shop</a>
    </div>
  </div>
  <script is:inline>
    const btn=document.getElementById("menuBtn");
    const menu=document.getElementById("mobileMenu");
    btn?.addEventListener("click",()=>menu?.classList.toggle("hidden"));
  </script>
</header>
