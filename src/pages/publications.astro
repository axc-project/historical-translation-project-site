---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import Card from "@components/Card.astro";
import Button from "@components/Button.astro";
import SectionHeading from "@components/SectionHeading.astro";
import { books } from "@data/books";
---
<BaseLayout title="Publications — Historical Translation Project™">
  <Container class="pt-14">
    <SectionHeading
      title="Publications"
      lede="Our research begins with texts. Each publication becomes a foundation for responsible translation into structured modern systems."
    />

    <div class="grid gap-6 md:grid-cols-2">
      {books.map((b) => (
        <Card class="p-7">
          <div class="flex gap-6">
            <div class="shrink-0 w-24">
              <div class="aspect-[2/3] rounded-xl2 overflow-hidden border border-gold-500/15 bg-white/5">
                <img src={b.coverImage ?? ""} alt={b.title} class="h-full w-full object-cover" />
              </div>
            </div>

            <div>
              <h2 class="font-serif text-2xl text-white">{b.title}</h2>
              <div class="mt-2 text-white/70">{b.subtitle}</div>
              <p class="mt-4 text-white/75 leading-relaxed">{b.description}</p>

              <div class="mt-6 flex flex-wrap gap-3">
                <Button href="/contact" variant="secondary">Request details</Button>
                <a
                  href={b.amazonUrl && b.amazonUrl.length ? b.amazonUrl : "#"}
                  class={`inline-flex items-center text-sm underline underline-offset-4 decoration-white/20 ${
                    b.amazonUrl && b.amazonUrl.length ? "text-white/75 hover:text-white" : "text-white/40 cursor-not-allowed"
                  }`}
                >
                  Amazon link (placeholder)
                </a>
              </div>
            </div>
          </div>
        </Card>
      ))}
    </div>
  </Container>
</BaseLayout>
