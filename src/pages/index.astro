---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import Button from "@components/Button.astro";
import Card from "@components/Card.astro";
import SectionHeading from "@components/SectionHeading.astro";
import { formulas } from "@data/formulas";
import { books } from "@data/books";

const heroImage = "/images/hero-landscape.png";
---

<BaseLayout
  title="Historical Translation Project™"
  description="Research-driven botanical frameworks rooted in historical texts and aligned with contemporary safety standards."
>
  <!-- HERO -->
  <section class="hero">
    <div class="heroBg" style={`background-image:url(${heroImage});`}></div>
    <div class="heroOverlay"></div>
    <div class="heroFade"></div>

    <Container class="heroInner">
      <div class="heroKicker">Historical Translation Project™</div>
      <h1 class="heroTitle">
        Translating Classical Medicine Into<br />Structured Modern Systems
      </h1>
      <p class="heroSub">
        Research-driven botanical frameworks rooted in historical texts and aligned with contemporary safety standards.
      </p>

      <div class="heroActions">
        <Button href="/formulations" variant="primary">Explore Formulations</Button>
        <Button href="/publications" variant="secondary">View Publications</Button>
      </div>
    </Container>
  </section>

  <!-- QUICK HIGHLIGHTS -->
  <section class="parchment">
    <Container>
      <div class="grid2">
        <Card
          variant="parchment"
          href="/formulations"
          ariaLabel="Go to formulations"
          class="highlightCard"
        >
          <div class="highlightTop">
            <div class="highlightEyebrow">Formulations</div>
            <div class="highlightTitle">Botanical Program Systems</div>
          </div>
          <p class="highlightText">
            A modular architecture: foundational cores first, with optional add-ons only when additional support is desired.*
          </p>
          <div class="highlightCTA">Browse Programs →</div>
        </Card>

        <Card
          variant="parchment"
          href="/publications"
          ariaLabel="Go to publications"
          class="highlightCard"
        >
          <div class="highlightTop">
            <div class="highlightEyebrow">Publications</div>
            <div class="highlightTitle">Foundational Texts</div>
          </div>
          <p class="highlightText">
            Our work begins with texts. Each publication becomes a foundation for responsible translation into structured modern systems.
          </p>
          <div class="highlightCTA">View Books →</div>
        </Card>
      </div>
    </Container>
  </section>

  <!-- PROGRAMS -->
  <section class="navySection">
    <Container>
      <SectionHeading
        title="Current Translational Programs"
        subtitle="Foundational cores designed as daily wellness systems—built with a disciplined, modular structure.*"
      />

      <div class="cardsGrid">
        {formulas.map((f) => (
          <Card
            variant="dark"
            href={`/formulations/${f.slug}`}
            ariaLabel={`View program ${f.name}`}
            class="programCard"
          >
            <div class="programMeta">
              <div class="programCategory">{f.category}</div>
            </div>

            <div class="programMain">
              <div class="programText">
                <h3 class="programTitle">{f.name}</h3>
                <p class="programTagline">{f.heroTagline}</p>

                <div class="programButtons">
                  <span class="miniBtn miniGold">View Program</span>
                  <span class="miniBtn miniGhost">Download Dossier</span>
                  <span class="miniBtn miniGhost">Purchase</span>
                </div>
              </div>

              <div class="programImageWrap">
                <div class="programImageFrame">
                  <img
                    src={f.image}
                    alt={`${f.name} bottle`}
                    class="programImage"
                    loading="lazy"
                  />
                </div>
              </div>
            </div>
          </Card>
        ))}
      </div>

      <p class="footnote">
        *Educational content only; not medical advice. These statements have not been evaluated by the Food and Drug Administration.
        This product is not intended to diagnose, treat, cure, or prevent any disease.
      </p>
    </Container>
  </section>

  <!-- FEATURED BOOKS -->
  <section class="parchment">
    <Container>
      <SectionHeading
        title="Featured Publications"
        subtitle="Structured translations that bridge historical doctrine with modern biological interpretation."
      />

      <div class="booksGrid">
        {books.map((b) => (
          <Card
            variant="parchment"
            href="/publications"
            ariaLabel={`View publications`}
            class="bookCard"
          >
            <div class="bookRow">
              <img class="bookCover" src={b.coverImage} alt={`${b.title} cover`} loading="lazy" />
              <div class="bookInfo">
                <div class="bookTitle">{b.title}</div>
                <div class="bookSubtitle">{b.subtitle}</div>
                <div class="bookLinkHint">See details & purchase links →</div>
              </div>
            </div>
          </Card>
        ))}
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  /* Layout tokens */
  .parchment { background: radial-gradient(1200px 700px at 30% 0%, rgba(212,175,55,.10), transparent 60%),
                        linear-gradient(#f4efe4, #efe7d7); padding: 56px 0; }
  .navySection { background: linear-gradient(#071523, #071a2b); padding: 70px 0; }

  /* HERO */
  .hero { position: relative; overflow: hidden; background: #071523; }
  .heroBg { position:absolute; inset:0; background-size:cover; background-position:center; transform: scale(1.02); }
  .heroOverlay { position:absolute; inset:0; background: radial-gradient(900px 500px at 25% 20%, rgba(7,21,35,.25), rgba(7,21,35,.68)); }
  .heroFade { position:absolute; inset:auto 0 0 0; height: 40%; background: linear-gradient(to bottom, rgba(0,0,0,0), rgba(244,239,228,.92)); }
  .heroInner { position: relative; padding: 88px 0 92px; }
  .heroKicker { letter-spacing: .18em; text-transform: uppercase; font-size: 12px; color: rgba(255,255,255,.78); }
  .heroTitle { margin-top: 14px; font-family: ui-serif, Georgia, "Times New Roman", Times, serif; font-weight: 600; font-size: clamp(34px, 4.2vw, 56px); line-height: 1.04; color: #fff; }
  .heroSub { margin-top: 16px; max-width: 62ch; color: rgba(255,255,255,.88); font-size: 16px; line-height: 1.6; }
  .heroActions { margin-top: 22px; display:flex; gap:12px; flex-wrap: wrap; }

  /* Highlights */
  .grid2 { display:grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .highlightCard { padding: 22px; }
  .highlightEyebrow { letter-spacing:.16em; text-transform:uppercase; font-size:12px; color: rgba(7,21,35,.70); }
  .highlightTitle { margin-top: 8px; font-family: ui-serif, Georgia, Times, serif; font-size: 26px; color: #071523; }
  .highlightText { margin-top: 10px; color: rgba(7,21,35,.78); line-height: 1.55; }
  .highlightCTA { margin-top: 14px; color: #0b2a44; font-weight: 600; }

  /* Program cards */
  .cardsGrid { margin-top: 22px; display:grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .programCard { padding: 22px; border: 1px solid rgba(212,175,55,.14); }
  .programCategory { letter-spacing:.16em; text-transform:uppercase; font-size: 11px; color: rgba(212,175,55,.85); }
  .programMain { margin-top: 12px; display:flex; gap: 18px; justify-content: space-between; align-items: flex-start; }
  .programTitle { font-family: ui-serif, Georgia, Times, serif; font-size: 26px; margin: 0; color: #fff; }
  .programTagline { margin-top: 8px; color: rgba(255,255,255,.85); line-height: 1.55; max-width: 52ch; }

  .programButtons { margin-top: 14px; display:flex; gap: 10px; flex-wrap: wrap; }
  .miniBtn { display:inline-block; padding: 10px 14px; border-radius: 999px; font-size: 13px; font-weight: 600; }
  .miniGold { background: #d4af37; color: #071523; }
  .miniGhost { background: rgba(255,255,255,.10); color: rgba(255,255,255,.92); border: 1px solid rgba(255,255,255,.16); }

  /* Bottle image treatment */
  .programImageWrap { flex: 0 0 140px; display:flex; justify-content:flex-end; }
  .programImageFrame {
    width: 132px; height: 132px; border-radius: 18px;
    background: radial-gradient(70px 70px at 50% 35%, rgba(212,175,55,.20), rgba(255,255,255,.08));
    border: 1px solid rgba(255,255,255,.16);
    display:flex; align-items:center; justify-content:center;
    overflow:hidden;
  }
  .programImage {
    width: 92px; height: auto;
    filter: drop-shadow(0 14px 18px rgba(0,0,0,.25));
    mix-blend-mode: multiply;
  }

  /* Books */
  .booksGrid { margin-top: 22px; display:grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .bookCard { padding: 18px; }
  .bookRow { display:flex; gap: 14px; align-items: center; }
  .bookCover { width: 72px; height: auto; border-radius: 10px; border: 1px solid rgba(7,21,35,.12); }
  .bookTitle { font-family: ui-serif, Georgia, Times, serif; font-size: 18px; color: #071523; }
  .bookSubtitle { margin-top: 4px; color: rgba(7,21,35,.75); }
  .bookLinkHint { margin-top: 10px; font-weight: 600; color: #0b2a44; }

  .footnote { margin-top: 22px; color: rgba(255,255,255,.70); font-size: 12px; line-height: 1.55; max-width: 95ch; }

  @media (max-width: 900px) {
    .grid2 { grid-template-columns: 1fr; }
    .cardsGrid { grid-template-columns: 1fr; }
    .booksGrid { grid-template-columns: 1fr; }
    .programImageWrap { flex-basis: 120px; }
  }
</style>
