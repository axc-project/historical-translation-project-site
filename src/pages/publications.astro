---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---
<BaseLayout title="Publications • Historical Translation Project™">
  <Header />
  <main class="mx-auto max-w-6xl px-4 py-14">
    <div class="max-w-3xl">
      <div class="kicker">Publications</div>
      <h1 class="mt-3 h-serif text-4xl sm:text-5xl">Foundational books</h1>
      <p class="mt-6 text-ink-900/70 leading-relaxed text-lg">
        Our publications are the primary sources that anchor the project and guide formulation design.
      </p>
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-2">
      <article class="card overflow-hidden">
        <div class="grid sm:grid-cols-[220px,1fr]">
          <div class="bg-parchment-100">
            <img src="/images/books/rambam-cover.jpg" alt="Rambam's Guide to Health cover" class="w-full h-full object-cover" />
          </div>
          <div class="p-8">
            <div class="kicker">Book</div>
            <h2 class="mt-2 h-serif text-2xl">Rambam’s Guide to Health</h2>
            <p class="mt-3 text-ink-900/70 leading-relaxed">
              A practical modern interpretation of medieval preventive medicine—focused on daily routine, digestion, balance, and long-term resilience.
            </p>
            <div class="mt-6 flex gap-3">
              <a class="btn-ghost" href="/research">Explore research</a>
              <a class="btn-primary" href="/contact">Request details</a>
            </div>
          </div>
        </div>
      </article>

      <article class="card overflow-hidden">
        <div class="grid sm:grid-cols-[220px,1fr]">
          <div class="bg-parchment-100 flex items-center justify-center p-6">
            <img src="/images/books/cancer-cover-placeholder.svg" alt="Cancer Across Time and Civilizations cover placeholder" class="w-full h-auto rounded-xl2 ring-1 ring-ink-900/10" />
          </div>
          <div class="p-8">
            <div class="kicker">Book</div>
            <h2 class="mt-2 h-serif text-2xl">Cancer Across Time and Civilizations</h2>
            <p class="mt-3 text-ink-900/70 leading-relaxed">
              A historical and biological translation—connecting long-form medical history with modern cellular systems, terrain, and resilience.
            </p>
            <div class="mt-6 flex gap-3">
              <a class="btn-ghost" href="/research">Explore research</a>
              <a class="btn-primary" href="/contact">Request details</a>
            </div>
          </div>
        </div>
      </article>
    </div>
  </main>
  <Footer />
</BaseLayout>
