---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---
<BaseLayout title="Historical Translation Project™">
  <Header />

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(215,181,109,0.22),transparent_55%)]"></div>
      <div class="mx-auto max-w-6xl px-4 pt-14 pb-12">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 rounded-full bg-white/70 ring-1 ring-ink-900/10 px-4 py-2 shadow-soft">
            <span class="h-2 w-2 rounded-full bg-gold-500"></span>
            <span class="text-sm text-ink-900/80">Historical foundations + modern evidence</span>
          </div>

          <h1 class="mt-8 h-serif text-5xl sm:text-6xl leading-[0.95] text-ink-900">
            A research-first approach to everyday botanical wellness.
          </h1>

          <p class="mt-6 text-lg leading-relaxed text-ink-900/75 max-w-2xl">
            We translate preventive principles from across global medical history into modern, evidence-forward educational dossiers—
            and thoughtfully designed botanical formulations framed in compliant structure/function language.
          </p>

          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            <a href="/formulations" class="btn-primary">Explore Formulations</a>
            <a href="/research" class="btn-ghost">Explore Research</a>
          </div>

          <p class="mt-4 text-xs text-ink-900/60">
            Educational content only; not medical advice. Supplements are not intended to diagnose, treat, cure, or prevent disease.
          </p>
        </div>

        <!-- Brand collage -->
        <div class="mt-12 card overflow-hidden">
          <img src="/images/brand/brand-collage.jpg" alt="Historical Translation Project brand collage" class="w-full h-auto" loading="eager" />
        </div>
      </div>
    </section>

    <!-- Section cards (instead of buttons) -->
    <section class="mx-auto max-w-6xl px-4 py-14">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <a href="/research" class="card p-7 hover:translate-y-[-2px] transition">
          <div class="kicker">Research</div>
          <div class="mt-2 h-serif text-2xl">Translational analyses</div>
          <p class="mt-3 text-ink-900/70">
            Historical textual analysis, modern evidence signals, and pathway-level interpretation—written for clinicians and curious patients.
          </p>
        </a>

        <a href="/publications" class="card p-7 hover:translate-y-[-2px] transition">
          <div class="kicker">Publications</div>
          <div class="mt-2 h-serif text-2xl">Foundational books</div>
          <p class="mt-3 text-ink-900/70">
            The publications that anchor our mission and inform every formulation—presented with clear summaries and links.
          </p>
        </a>

        <a href="/formulations" class="card p-7 hover:translate-y-[-2px] transition">
          <div class="kicker">Formulations</div>
          <div class="mt-2 h-serif text-2xl">Structured programs</div>
          <p class="mt-3 text-ink-900/70">
            A clean system of core formulas and targeted add-ons—built to minimize pill burden and avoid unnecessary overlap.
          </p>
        </a>

        <a href="/method" class="card p-7 hover:translate-y-[-2px] transition">
          <div class="kicker">Method</div>
          <div class="mt-2 h-serif text-2xl">Bridge old + new</div>
          <p class="mt-3 text-ink-900/70">
            Our formulations bridge historically proven approaches with modern-day data and studies to create targeted support supplements.
          </p>
        </a>

        <a href="/shop" class="card p-7 hover:translate-y-[-2px] transition">
          <div class="kicker">Shop</div>
          <div class="mt-2 h-serif text-2xl">Order processing</div>
          <p class="mt-3 text-ink-900/70">
            Shopify-ready architecture for payments, order capture, and fulfillment-center handoff (when enabled).
          </p>
        </a>

        <a href="/contact" class="card p-7 hover:translate-y-[-2px] transition">
          <div class="kicker">Contact</div>
          <div class="mt-2 h-serif text-2xl">Collaborate</div>
          <p class="mt-3 text-ink-900/70">
            Physicians, researchers, and partners—reach out for dossiers, sourcing notes, or collaboration opportunities.
          </p>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
