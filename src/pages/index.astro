---
import BaseLayout from '../layouts/BaseLayout.astro';
import { formulations } from '../data/formulations.js';

const title = 'Historical Translation Project™ — Historical foundations + modern evidence';
const description = 'A research-first approach to everyday botanical wellness: educational dossiers, historical excerpts, and modern evidence summaries.';

const featured = formulations;
---
<BaseLayout title={title} description={description} canonical="/">
  <!-- HERO -->
  <section class="relative bg-parchment-50">
    <div class="relative overflow-hidden">
      <div class="absolute inset-0 bg-parchment"></div>
      <div class="absolute inset-0 opacity-40 grain"></div>

      <div class="mx-auto max-w-6xl px-4 py-14 lg:py-20 relative">
        <div class="grid gap-10 lg:grid-cols-12 lg:items-center">
          <div class="lg:col-span-6">
            <div class="inline-flex items-center gap-2 rounded-full border border-slate-900/10 bg-white/70 px-4 py-2 text-xs text-slate-700 shadow-soft">
              <span class="h-2 w-2 rounded-full bg-gold-400"></span>
              Historical foundations + modern evidence
            </div>

            <h1 class="mt-6 text-4xl sm:text-5xl lg:text-6xl text-navy-950">
              A research-first approach to everyday botanical wellness.
            </h1>
            <p class="mt-5 text-lg text-slate-700 leading-relaxed max-w-xl">
              We translate preventive principles from across global medical history into modern, evidence-forward educational dossiers—and
              thoughtfully designed botanical formulations framed in compliant structure/function language.
            </p>

            <div class="mt-7 flex flex-col sm:flex-row gap-3">
              <a href="/supplements" class="btn-gold inline-flex items-center justify-center rounded-full bg-gold-400 px-6 py-3 text-sm font-semibold text-navy-950 shadow-glow hover:bg-gold-200 transition">
                Explore Formulations
              </a>
              <a href="/dossiers" class="inline-flex items-center justify-center rounded-full border border-navy-950/15 bg-white/70 px-6 py-3 text-sm font-semibold text-navy-950 hover:bg-white transition">
                Download Dossiers
              </a>
            </div>

            <p class="mt-4 text-xs text-slate-600">
              Educational content only; not medical advice. Supplements are not intended to diagnose, treat, cure, or prevent disease.
            </p>
          </div>

          <div class="lg:col-span-6">
            <div class="relative rounded-3xl bg-navy-950 shadow-soft overflow-hidden">
              <div class="absolute inset-0 bg-navy-radial"></div>
              <div class="absolute inset-0 opacity-50 grain"></div>
              <div class="relative p-4 sm:p-6">
                <div class="rounded-2xl overflow-hidden border border-white/10 shadow-glow">
                  <img src="/images/hero-bottles.jpg" alt="Historical Translation Project botanical formulations" class="w-full h-auto" loading="eager" />
                </div>
                <div class="mt-4 grid grid-cols-3 gap-3">
                  <div class="rounded-2xl bg-white/7 border border-white/10 p-3 text-center">
                    <div class="text-gold-200 text-xs font-semibold">Historically grounded</div>
                    <div class="mt-1 text-white/75 text-xs">Primary texts + tradition</div>
                  </div>
                  <div class="rounded-2xl bg-white/7 border border-white/10 p-3 text-center">
                    <div class="text-gold-200 text-xs font-semibold">Evidence supported</div>
                    <div class="mt-1 text-white/75 text-xs">Modern summaries</div>
                  </div>
                  <div class="rounded-2xl bg-white/7 border border-white/10 p-3 text-center">
                    <div class="text-gold-200 text-xs font-semibold">Designed to stack</div>
                    <div class="mt-1 text-white/75 text-xs">Cores + modules</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CURRENT FORMULATIONS -->
  <section class="bg-parchment-50">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <div class="flex items-end justify-between gap-6">
        <div>
          <h2 class="text-3xl sm:text-4xl text-navy-950">Explore the current formulations</h2>
          <p class="mt-3 text-slate-700 max-w-2xl">
            Our catalog will expand as we publish more books and research new traditions. Each product page includes: an overview,
            historical foundations, modern evidence signals, a clean ingredient story, and optional add-on recommendations.
          </p>
        </div>
        <a href="/supplements" class="hidden sm:inline-flex rounded-full border border-navy-950/15 bg-white px-5 py-2 text-sm font-semibold text-navy-950 hover:bg-white/70">
          View all
        </a>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {featured.map((f) => (
          <article class="group rounded-3xl border border-navy-950/10 bg-white/70 p-7 shadow-soft hover:shadow-glow transition">
            <div class="flex items-start justify-between gap-4">
              <div>
                <div class="text-xs uppercase tracking-wide text-slate-600">{f.status}</div>
                <h3 class="mt-2 text-2xl text-navy-950">{f.name}</h3>
                <p class="mt-2 text-sm text-slate-700">{f.subtitle}</p>
              </div>
              <div class="h-10 w-10 rounded-2xl bg-navy-950 text-gold-200 flex items-center justify-center border border-white/10">
                <span class="font-serif text-lg">H</span>
              </div>
            </div>
            <p class="mt-4 text-sm text-slate-700 leading-relaxed">{f.summary}</p>
            <ul class="mt-4 space-y-2 text-sm text-slate-700">
              {f.bullets.map((b) => (
                <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-gold-400"></span><span>{b}</span></li>
              ))}
            </ul>
            <div class="mt-6 flex items-center gap-3">
              <a href={`/supplements/${f.slug}`} class="inline-flex items-center justify-center rounded-full bg-navy-950 px-5 py-2 text-sm font-semibold text-white hover:bg-navy-800">Learn More</a>
              <a href="/dossiers" class="text-sm font-semibold text-navy-950/80 hover:text-navy-950">Download dossier</a>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-8 sm:hidden">
        <a href="/supplements" class="inline-flex rounded-full border border-navy-950/15 bg-white px-5 py-2 text-sm font-semibold text-navy-950 hover:bg-white/70">View all</a>
      </div>
    </div>
  </section>

  <!-- STACKING GUIDE -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
        <div>
          <h2 class="text-3xl sm:text-4xl text-navy-950">How the system works</h2>
          <p class="mt-3 text-slate-700 leading-relaxed">
            We design a <span class="font-semibold">foundational stack</span> (daily cores) and <span class="font-semibold">targeted modules</span>
            (optional add‑ons) so you can personalize without building an overwhelming cabinet.
          </p>
          <div class="mt-6 grid gap-4">
            <div class="rounded-2xl border border-slate-200 bg-parchment-50 p-5">
              <div class="font-semibold text-navy-950">Step 1 — Choose a foundation</div>
              <div class="mt-1 text-sm text-slate-700">Start with a core formula aligned with your daily baseline goals.</div>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-parchment-50 p-5">
              <div class="font-semibold text-navy-950">Step 2 — Add a targeted module (optional)</div>
              <div class="mt-1 text-sm text-slate-700">Layer in a curated add‑on only when it adds something truly distinct.</div>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-parchment-50 p-5">
              <div class="font-semibold text-navy-950">Step 3 — Use dossiers to decide</div>
              <div class="mt-1 text-sm text-slate-700">Each product includes historical context and a modern evidence overview.</div>
            </div>
          </div>
          <div class="mt-7">
            <a href="/method" class="btn-gold inline-flex items-center justify-center rounded-full bg-gold-400 px-6 py-3 text-sm font-semibold text-navy-950 shadow-glow hover:bg-gold-200 transition">Read the method</a>
          </div>
        </div>

        <div class="rounded-3xl bg-navy-950 overflow-hidden shadow-soft relative">
          <div class="absolute inset-0 bg-navy-radial"></div>
          <div class="absolute inset-0 opacity-40 grain"></div>
          <div class="relative p-8">
            <div class="text-gold-200 font-semibold">Example Stack</div>
            <div class="mt-2 text-white font-serif text-3xl">Foundation + Targeted</div>
            <div class="mt-6 grid gap-4">
              <div class="rounded-2xl bg-white/8 border border-white/10 p-5">
                <div class="text-white font-semibold">Foundational</div>
                <div class="mt-1 text-white/75 text-sm">Digestive Metabolic Core™ or Circulatory Vitality Core™</div>
              </div>
              <div class="rounded-2xl bg-white/8 border border-white/10 p-5">
                <div class="text-white font-semibold">Targeted Modules</div>
                <div class="mt-1 text-white/75 text-sm">Urinary Flow Support™ + other curated add‑ons (as needed)</div>
              </div>
              <div class="rounded-2xl bg-white/8 border border-white/10 p-5">
                <div class="text-white font-semibold">Shopify-ready</div>
                <div class="mt-1 text-white/75 text-sm">When enabled, add‑ons can be purchased as recommended modules.</div>
              </div>
            </div>
            <div class="mt-6 text-white/70 text-xs">Checkout is coming soon. For now, use the email button to be notified.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BOOK FEATURE -->
  <section class="bg-parchment-50">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <div class="grid gap-10 lg:grid-cols-12 lg:items-center">
        <div class="lg:col-span-5">
          <div class="rounded-3xl bg-navy-950 overflow-hidden shadow-soft border border-white/10">
            <img src="/images/rambam-bookcover.jpg" alt="Rambam's Guide to Health book cover" class="w-full h-auto" loading="lazy" />
          </div>
        </div>
        <div class="lg:col-span-7">
          <div class="inline-flex items-center gap-2 rounded-full border border-slate-900/10 bg-white/70 px-4 py-2 text-xs text-slate-700 shadow-soft">
            Featured publication
          </div>
          <h2 class="mt-5 text-3xl sm:text-4xl text-navy-950">Rambam’s Guide to Health</h2>
          <p class="mt-3 text-slate-700 leading-relaxed">
            Our first major project translates preventive medicine principles from Rambam’s writings into a practical modern interpretation.
            The companion pages and dossiers connect historical excerpts with modern context—without making medical claims.
          </p>
          <div class="mt-6 flex flex-col sm:flex-row gap-3">
            <a class="btn-gold inline-flex items-center justify-center rounded-full bg-gold-400 px-6 py-3 text-sm font-semibold text-navy-950 shadow-glow hover:bg-gold-200 transition" href="/book">Read about the book</a>
            <a class="inline-flex items-center justify-center rounded-full border border-navy-950/15 bg-white/70 px-6 py-3 text-sm font-semibold text-navy-950 hover:bg-white" href="https://www.amazon.com/dp/B0GPNWH877">Buy on Amazon</a>
          </div>
          <p class="mt-4 text-xs text-slate-600">Amazon link opens in a new tab. Kindle and paperback availability may vary by region.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
