---
import Base from "../../layouts/Base.astro";
import { FORMULAS } from "../../data/site";

const formula = FORMULAS.find((f) => f.slug === "digestive-metabolic-core");
if (!formula) throw new Error("Formula not found");
---

<Base title={`${formula.name} — Historical Translation Project™`}>
  <section class="mx-auto max-w-6xl px-5 py-12 sm:py-16">
    <div class="grid lg:grid-cols-12 gap-10 items-start">
      <div class="lg:col-span-7">
        <div class="inline-flex items-center gap-2 rounded-full bg-parchment2 ring-1 ring-black/10 px-4 py-2">
          <span class="w-2 h-2 rounded-full bg-gold"></span>
          <span class="tracking-wide text-ink/70">Program</span>
        </div>
        <h1 class="mt-6 font-display text-4xl sm:text-5xl text-ink leading-tight">{formula.name}</h1>
        <div class="mt-2 text-xl text-ink/65">{formula.focus}</div>
        <p class="mt-6 text-xl text-ink/75 leading-relaxed">{formula.short}</p>

        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <a href="/shop" class="no-underline hover:no-underline inline-flex justify-center rounded-md bg-gold text-ink font-semibold px-7 py-3 hover:bg-gold2 transition">
            Purchase (Coming Soon)
          </a>
          <a href="/contact" class="no-underline hover:no-underline inline-flex justify-center rounded-md bg-parchment2 ring-1 ring-black/10 px-7 py-3 hover:bg-parchment transition">
            Request updates
          </a>
        </div>

        <ul class="mt-10 space-y-2 text-lg text-ink/75 list-disc list-inside">
          {formula.heroBullets.map((b) => <li>{b}</li>)}
        </ul>
      </div>

      <div class="lg:col-span-5">
        <div class="rounded-2xl overflow-hidden ring-1 ring-black/10 shadow-soft">
          <img src="/images/brand-collage.jpg" alt="Program imagery" class="w-full h-[420px] object-cover" />
        </div>
      </div>
    </div>

    <div class="mt-14 grid lg:grid-cols-12 gap-8">
      <div class="lg:col-span-7 rounded-2xl bg-white/70 ring-1 ring-black/5 shadow-card p-8">
        <div class="font-display text-2xl">Overview</div>
        <div class="mt-4 space-y-4 text-lg text-ink/75 leading-relaxed">
          {formula.overview.map((p) => <p>{p}</p>)}
        </div>
      </div>
      <div class="lg:col-span-5 rounded-2xl bg-white/70 ring-1 ring-black/5 shadow-card p-8">
        <div class="font-display text-2xl">Historical foundations</div>
        <p class="mt-4 text-lg text-ink/75 leading-relaxed">
          We keep the program rooted in historical preventive traditions, then translate it into modern, conservative structure/function language.
        </p>
        <div class="mt-6 font-display text-2xl">Modern overview</div>
        <p class="mt-4 text-lg text-ink/75 leading-relaxed">
          We evaluate plausibility, safety, and evidence signals—then present only compliant, non‑disease structure/function statements.
        </p>
      </div>
    </div>

    <div class="mt-10 rounded-2xl bg-parchment2 ring-1 ring-black/10 p-8 shadow-soft">
      <div class="font-display text-3xl">Ingredient story</div>
      <p class="mt-3 text-lg text-ink/70">A clean hierarchy: ingredient → historical root → modern overview → formulation notes.</p>

      <div class="mt-8 grid md:grid-cols-2 gap-6">
        {formula.ingredientStory.map((ing) => (
          <div class="rounded-xl bg-white/70 ring-1 ring-black/5 p-6">
            <div class="font-display text-2xl text-ink">{ing.name}</div>
            <div class="mt-3 text-sm tracking-[.22em] uppercase text-ink/55">Historical</div>
            <p class="mt-2 text-lg text-ink/75 leading-relaxed">{ing.historical}</p>
            <div class="mt-4 text-sm tracking-[.22em] uppercase text-ink/55">Modern</div>
            <p class="mt-2 text-lg text-ink/75 leading-relaxed">{ing.modern}</p>
            {ing.notes && <p class="mt-4 text-sm text-ink/60"><span class="font-semibold">Note:</span> {ing.notes}</p>}
          </div>
        ))}
      </div>
    </div>

    <div class="mt-12 grid lg:grid-cols-12 gap-8 items-start">
      <div class="lg:col-span-7 rounded-2xl bg-white/70 ring-1 ring-black/5 shadow-card p-8">
        <div class="font-display text-3xl">Add‑ons</div>
        <p class="mt-3 text-lg text-ink/70 leading-relaxed">
          Add‑ons are optional and included only when a targeted need is not already addressed by the core program.
          Where appropriate, we’ll recommend vetted third‑party products that can be purchased via Shopify once enabled.
        </p>
        <div class="mt-7 space-y-6">
          {formula.addOns.map((block) => (
            <div>
              <div class="font-display text-2xl">{block.title}</div>
              <ul class="mt-3 space-y-3 text-lg text-ink/75 list-disc list-inside">
                {block.items.map((it) => (
                  <li><span class="font-semibold">{it.name}:</span> {it.why}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <div class="lg:col-span-5 rounded-2xl bg-navy text-parchment p-8 shadow-soft relative overflow-hidden grain">
        <div class="absolute inset-0 opacity-25"
             style="background-image: linear-gradient(180deg, rgba(11,26,42,.95), rgba(11,26,42,.55)), url('/images/hero-mountains.jpg'); background-size: cover; background-position: center;"></div>
        <div class="relative">
          <div class="font-display text-3xl text-gold2">Cautions</div>
          <ul class="mt-4 space-y-3 text-parchment/85 text-lg list-disc list-inside">
            {formula.cautions.map((c) => <li>{c}</li>)}
          </ul>
          <p class="mt-8 text-sm text-parchment/65">
            Educational content only; not medical advice. Supplements are not intended to diagnose, treat, cure, or prevent disease.
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>
