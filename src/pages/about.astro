---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'About — Historical Translation Project™';
const description = 'About the Historical Translation Project™: translating historical health traditions into modern, evidence-forward education and botanical formulations.';
---
<BaseLayout title={title} description={description} canonical="/about">
  <section class="bg-parchment-50">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <div class="grid gap-10 lg:grid-cols-12 lg:items-start">
        <div class="lg:col-span-7">
          <div class="inline-flex items-center gap-2 rounded-full border border-slate-900/10 bg-white/70 px-4 py-2 text-xs text-slate-700 shadow-soft">About</div>
          <h1 class="mt-6 text-4xl sm:text-5xl text-navy-950">Why we exist</h1>
          <p class="mt-4 text-lg text-slate-700 leading-relaxed">
            Historical Translation Project™ is a research initiative that translates ancient and medieval preventive medicine ideas into modern,
            evidence-forward education—paired with thoughtfully designed botanical formulations.
          </p>

          <div class="mt-8 space-y-4 text-slate-700 prose-htp">
            <p>
              Across civilizations, preventive health traditions emphasized digestion, routine, movement, sleep, temperament, and food.
              Our work is to extract those durable principles, present them clearly, and connect them to modern evidence without overclaiming.
            </p>
            <p>
              We publish books (starting with <span class="font-semibold">Rambam’s Guide to Health</span>), create downloadable dossiers,
              and curate a modular supplement system—built around foundational cores plus targeted add‑ons.
            </p>
          </div>

          <div class="mt-10 grid gap-4 sm:grid-cols-2">
            <div class="rounded-2xl border border-slate-200 bg-white/70 p-6 shadow-soft">
              <div class="font-semibold text-navy-950">Mission</div>
              <p class="mt-2 text-sm text-slate-700">Research ancient remedies across global history and integrate them responsibly with modern scientific evidence.</p>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-white/70 p-6 shadow-soft">
              <div class="font-semibold text-navy-950">Principles</div>
              <p class="mt-2 text-sm text-slate-700">Clarity over hype • conservative claims • clean formulas • evidence signals • scalable education.</p>
            </div>
          </div>

          <div class="mt-10 rounded-3xl border border-navy-950/10 bg-white/70 p-8 shadow-soft">
            <h2 class="text-2xl text-navy-950">What makes this different</h2>
            <ul class="mt-4 space-y-2 text-sm text-slate-700">
              <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-gold-400"></span><span>We start from primary historical themes—not marketing trends.</span></li>
              <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-gold-400"></span><span>We summarize modern evidence conservatively and transparently.</span></li>
              <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-gold-400"></span><span>We design a modular system to avoid “kitchen sink” supplements.</span></li>
              <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-gold-400"></span><span>Everything is written in compliant, non‑medical language.</span></li>
            </ul>
          </div>
        </div>

        <div class="lg:col-span-5">
          <div class="rounded-3xl bg-navy-950 overflow-hidden shadow-soft relative">
            <div class="absolute inset-0 bg-navy-radial"></div>
            <div class="absolute inset-0 opacity-40 grain"></div>
            <div class="relative p-8">
              <div class="text-gold-200 text-xs uppercase tracking-wide">Start here</div>
              <h2 class="mt-2 font-serif text-3xl text-white">Explore the ecosystem</h2>
              <div class="mt-6 grid gap-4">
                <a class="rounded-2xl bg-white/8 border border-white/10 p-5 hover:bg-white/10" href="/book">
                  <div class="text-white font-semibold">The Book</div>
                  <div class="mt-1 text-white/75 text-sm">Rambam’s Guide to Health</div>
                </a>
                <a class="rounded-2xl bg-white/8 border border-white/10 p-5 hover:bg-white/10" href="/supplements">
                  <div class="text-white font-semibold">Supplements</div>
                  <div class="mt-1 text-white/75 text-sm">Foundational formulas + targeted modules</div>
                </a>
                <a class="rounded-2xl bg-white/8 border border-white/10 p-5 hover:bg-white/10" href="/dossiers">
                  <div class="text-white font-semibold">Dossiers</div>
                  <div class="mt-1 text-white/75 text-sm">Download printable PDFs</div>
                </a>
              </div>
              <div class="mt-6">
                <a class="btn-gold inline-flex items-center justify-center rounded-full bg-gold-400 px-6 py-3 text-sm font-semibold text-navy-950 shadow-glow hover:bg-gold-200" href="mailto:info@axellaresearch.com?subject=HTP%20Updates">Get launch updates</a>
              </div>
              <p class="mt-4 text-xs text-white/60">Educational content only; not medical advice.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
