---
const { compact = false } = Astro.props;
---
<div class="flex items-center gap-3">
  <img src="/brand/htp-logo.png" alt="Historical Translation Project™" class={compact ? "h-9 w-auto" : "h-12 w-auto"} />
  <div class="leading-tight">
    <div class={"font-serif font-semibold tracking-tight text-navy " + (compact ? "text-base" : "text-xl")}>Historical Translation Project™</div>
    {!compact && <div class="text-xs text-muted">Historically grounded • Evidence supported</div>}
  </div>
</div>
