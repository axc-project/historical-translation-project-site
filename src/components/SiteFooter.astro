---
import Container from "./Container.astro";
const year = new Date().getFullYear();
---
<footer class="mt-20 border-t border-gold-500/15 bg-navy-900/60">
  <Container class="py-10">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-10">
      <div>
        <div class="text-white font-serif text-xl tracking-tight">Historical Translation Project™</div>
        <p class="mt-3 max-w-md text-white/70 leading-relaxed">
          Translating classical medical doctrine into structured modern systems—research-driven,
          carefully framed, and aligned with contemporary safety standards.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-8 text-sm">
        <div>
          <div class="text-white/85 uppercase tracking-[0.22em] text-[11px]">Explore</div>
          <div class="mt-3 space-y-2">
            <a class="block text-white/70 hover:text-white" href="/publications">Publications</a>
            <a class="block text-white/70 hover:text-white" href="/formulations">Formulations</a>
            <a class="block text-white/70 hover:text-white" href="/about">About</a>
          </div>
        </div>
        <div>
          <div class="text-white/85 uppercase tracking-[0.22em] text-[11px]">Contact</div>
          <div class="mt-3 space-y-2">
            <a class="block text-white/70 hover:text-white" href="/contact">Research Inquiries</a>
            <a class="block text-white/70 hover:text-white" href="mailto:info@axellaresearch.com">info@axellaresearch.com</a>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-10 gold-hairline"></div>

    <div class="mt-8 text-xs leading-relaxed text-white/60 space-y-2">
      <p>Educational content only; not medical advice.</p>
      <p>These statements have not been evaluated by the Food and Drug Administration.</p>
      <p>This product is not intended to diagnose, treat, cure, or prevent any disease.</p>
    </div>

    <div class="mt-8 text-xs text-white/45">
      © {year} Historical Translation Project™. All rights reserved.
    </div>
  </Container>
</footer>
