---
import BaseLayout from '../layouts/BaseLayout.astro';
import { formulations } from '../data/formulations.js';

const title = 'Supplements — Historical Translation Project™';
const description = 'Explore foundational formulas and targeted add-on modules. Each page includes historical foundations, a modern evidence overview, and clean ingredient narratives.';
---
<BaseLayout title={title} description={description} canonical="/supplements">
  <section class="bg-parchment-50">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 rounded-full border border-slate-900/10 bg-white/70 px-4 py-2 text-xs text-slate-700 shadow-soft">Formulations</div>
        <h1 class="mt-6 text-4xl sm:text-5xl text-navy-950">Foundational formulas + targeted modules</h1>
        <p class="mt-4 text-lg text-slate-700 leading-relaxed">
          We avoid rigid marketing labels that lock us into a fixed number of “core” products. As our research expands and we publish more
          books, this catalog will grow—while keeping the system easy to understand.
        </p>
        <div class="mt-6 rounded-2xl border border-slate-200 bg-white/70 p-6">
          <div class="font-semibold text-navy-950">Purchase status</div>
          <p class="mt-1 text-sm text-slate-700">Shopify checkout is coming soon. For now, you can request an update via email.</p>
          <a href="mailto:info@axellaresearch.com?subject=HTP%20Updates" class="mt-4 inline-flex items-center justify-center rounded-full bg-navy-950 px-5 py-2 text-sm font-semibold text-white hover:bg-navy-800">Notify me</a>
        </div>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {formulations.map((f) => (
          <article class="rounded-3xl border border-navy-950/10 bg-white/70 p-7 shadow-soft">
            <div class="text-xs uppercase tracking-wide text-slate-600">{f.status}</div>
            <h2 class="mt-2 text-2xl text-navy-950">{f.name}</h2>
            <p class="mt-2 text-sm text-slate-700">{f.subtitle}</p>
            <p class="mt-4 text-sm text-slate-700 leading-relaxed">{f.summary}</p>
            <div class="mt-6 flex items-center gap-3">
              <a href={`/supplements/${f.slug}`} class="inline-flex items-center justify-center rounded-full bg-navy-950 px-5 py-2 text-sm font-semibold text-white hover:bg-navy-800">View details</a>
              <a href="/dossiers" class="text-sm font-semibold text-navy-950/80 hover:text-navy-950">Download dossier</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
