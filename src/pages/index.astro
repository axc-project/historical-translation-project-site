---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import Button from "@components/Button.astro";
import Card from "@components/Card.astro";
import SectionHeading from "@components/SectionHeading.astro";
import { formulas } from "@data/formulas";
import { books } from "@data/books";

const heroImage = "/images/hero-landscape.png";
---

<BaseLayout
  title="Historical Translation Project™"
  description="Research-driven botanical frameworks rooted in historical texts and aligned with contemporary safety standards."
>

  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div
        class="h-full w-full"
        style={`background-image:url(${heroImage}); background-size:cover; background-position:center; opacity:.85;`}
      ></div>

      <div class="absolute inset-0 heroOverlay"></div>
    </div>

    <Container class="relative py-16 md:py-24">
      <div class="max-w-3xl">
        <div class="text-[12px] uppercase tracking-[0.28em] text-white/70">
          Historical Translation Project™
        </div>

        <h1 class="mt-5 font-serif text-4xl sm:text-5xl text-white leading-tight">
          Translating Classical Medicine Into Structured Modern Systems
        </h1>

        <p class="mt-6 text-white/85 text-lg max-w-2xl">
          Research-driven botanical frameworks rooted in historical texts and aligned with contemporary safety standards.
        </p>

        <div class="mt-10 flex gap-4 flex-wrap">
          <Button href="/formulations" variant="primary">Explore Formulations</Button>
          <Button href="/publications" variant="secondary">View Publications</Button>
        </div>
      </div>
    </Container>

    <div class="pointer-events-none absolute inset-x-0 bottom-0 h-28 bg-gradient-to-b from-transparent via-[rgba(246,241,230,.45)] to-[rgb(246,241,230)]"></div>
  </section>

  <!-- FORMULATIONS -->
  <section class="parchment-section">
    <Container>
      <SectionHeading
        title="Formulations"
        lede="A modular architecture: foundational cores first, with optional add-ons only when additional support is desired.*"
      />

      <div class="grid gap-6 md:grid-cols-2">
        {formulas.map((f) => (
          <Card class="p-7 card-hover">
            <div class="flex justify-between gap-6">
              <div>
                <div class="text-[11px] uppercase tracking-[0.22em] text-gold-500">
                  {f.category}
                </div>
                <h3 class="mt-3 font-serif text-2xl">{f.name}</h3>
                <p class="mt-3">{f.heroTagline}</p>
              </div>

              {f.bottleImage && (
                <div class="hidden sm:block w-20 h-20">
                  <img src={f.bottleImage} class="bottleImg object-contain w-full h-full" />
                </div>
              )}
            </div>
          </Card>
        ))}
      </div>
    </Container>
  </section>

</BaseLayout>
