---
import Container from "./Container.astro";

const pathname = Astro.url?.pathname ?? "/";

const nav = [
  { label: "Research", href: "/" },
  { label: "Publications", href: "/publications" },
  { label: "Formulations", href: "/formulations" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" }
];

const { logoSrc = "/images/htp-logo.png" } = Astro.props;
---
<header class="sticky top-0 z-50 backdrop-blur-md bg-navy-900/70 border-b border-gold-500/15">
  <Container class="py-4">
    <div class="flex items-center justify-between gap-4">
      <a href="/" class="flex items-center gap-3 min-w-0">
        <img
          src={logoSrc}
          alt="Historical Translation Project™"
          class="h-14 w-auto sm:h-16 md:h-[72px] shrink-0"
          style="max-height:72px"
        />
        <div class="hidden sm:block min-w-0">
          <div class="text-[12px] tracking-[0.22em] uppercase text-white/85 truncate">
            Historical Translation Project™
          </div>
          <div class="text-white/65 text-xs tracking-wide truncate">
            Research • Publications • Formulations
          </div>
        </div>
      </a>

      <nav class="hidden lg:flex items-center gap-7">
        {nav.map((item) => (
          (() => {
            const isActive =
              item.href === "/"
                ? pathname === "/"
                : pathname === item.href || pathname.startsWith(item.href + "/");

            const base =
              "relative text-[12px] uppercase tracking-[0.22em] transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-gold-500/40 rounded";
            const active =
              "text-white after:absolute after:left-0 after:right-0 after:-bottom-2 after:h-px after:bg-gold-500/70";
            const inactive = "text-white/75 hover:text-white";

            return (
          <a
            href={item.href}
            class={`${base} ${isActive ? active : inactive}`}
          >
            {item.label}
          </a>
            );
          })()
        ))}
      </nav>

      <a
        href="/shop"
        class="hidden sm:inline-flex rounded-xl2 border border-gold-500/20 bg-white/5 px-4 py-2 text-[12px] uppercase tracking-[0.22em] text-white/80 hover:text-white hover:border-gold-500/35 transition"
      >
        Shop
      </a>
    </div>

    <div class="lg:hidden mt-4 flex flex-wrap gap-3">
      {nav.map((item) => (
        (() => {
          const isActive =
            item.href === "/"
              ? pathname === "/"
              : pathname === item.href || pathname.startsWith(item.href + "/");
          const base =
            "rounded-xl2 border bg-white/5 px-3 py-2 text-[11px] uppercase tracking-[0.2em] transition focus:outline-none focus-visible:ring-2 focus-visible:ring-gold-500/40";
          const active = "border-gold-500/35 text-white shadow-glow";
          const inactive = "border-white/10 text-white/75 hover:text-white hover:border-gold-500/25";
          return (
        <a
          href={item.href}
          class={`${base} ${isActive ? active : inactive}`}
        >
          {item.label}
        </a>
          );
        })()
      ))}
      <a
        href="/shop"
        class="sm:hidden rounded-xl2 border border-gold-500/20 bg-white/5 px-3 py-2 text-[11px] uppercase tracking-[0.2em] text-white/80 hover:text-white hover:border-gold-500/35 transition"
      >
        Shop
      </a>
    </div>
  </Container>
</header>
