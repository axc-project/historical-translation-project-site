---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/Button.astro";
import { getFormulationBySlug } from "../../data/formulations.js";
import { buildMailto } from "../../utils/cta.js";
const { slug } = Astro.params;
const f = getFormulationBySlug(slug);
if (!f) throw new Error("Formulation not found");
---
<BaseLayout title={`${f.name} • Historical Translation Project™`}>
  <section class="mx-auto max-w-6xl px-4 pt-10 pb-16">
    <div class="grid lg:grid-cols-12 gap-8 items-start">
      <div class="lg:col-span-8">
        <div class="text-xs font-semibold tracking-widest text-gold">{f.tier} FORMULA</div>
        <h1 class="mt-2 font-serif text-4xl md:text-5xl text-navy">{f.name}</h1>
        <p class="mt-3 text-muted text-lg max-w-3xl">{f.heroTagline}</p>

        <div class="mt-6 flex flex-wrap gap-3">
          <Button href={f.purchase.href} variant="gold" text={f.purchase.label} />
          <Button href={buildMailto(f.cta)} variant="secondary" text="Notify Me" external={true} />
          <Button href="/book" variant="secondary" text="Book" />
          <Button href="/projects/rambam" variant="secondary" text="Rambam Project" />
        </div>

        <div class="mt-8 rounded-xl2 bg-card shadow-soft border border-line p-6">
          <div class="text-xs font-semibold tracking-widest text-gold">OVERVIEW</div>
          <h2 class="mt-2 font-serif text-2xl text-navy">What it is</h2>
          <p class="mt-3 text-sm text-muted leading-relaxed">{f.overview}</p>
          <p class="mt-4 text-sm text-muted">{f.serving}</p>
        </div>

        {f.formulaTable && (
          <div class="mt-6 rounded-xl2 bg-card shadow-soft border border-line p-6">
            <div class="text-xs font-semibold tracking-widest text-gold">FORMULA</div>
            <h2 class="mt-2 font-serif text-2xl text-navy">{f.formulaTable.title}</h2>
            <div class="mt-4 overflow-hidden rounded-xl2 border border-line">
              <table class="w-full text-sm">
                <thead class="bg-parchment">
                  <tr>
                    <th class="text-left px-4 py-3 font-semibold text-navy">Ingredient</th>
                    <th class="text-right px-4 py-3 font-semibold text-navy">Amount</th>
                  </tr>
                </thead>
                <tbody>
                  {f.formulaTable.rows.map(r => (
                    <tr class="border-t border-line">
                      <td class="px-4 py-3 text-muted">{r[0]}</td>
                      <td class="px-4 py-3 text-right font-semibold text-navy">{r[1]}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <ul class="mt-4 list-disc pl-5 space-y-1 text-xs text-muted">
              {f.formulaTable.notes.map(n => <li>{n}</li>)}
            </ul>
          </div>
        )}

        <div class="mt-6 space-y-6">
          {f.blocks.map(b => (
            <div class="rounded-xl2 bg-card shadow-soft border border-line p-6">
              <h2 class="font-serif text-2xl text-navy">{b.heading}</h2>
              {b.body && <p class="mt-3 text-sm text-muted leading-relaxed">{b.body}</p>}
              {b.bullets && (
                <ul class="mt-4 list-disc pl-5 space-y-2 text-sm text-muted">
                  {b.bullets.map(x => <li>{x}</li>)}
                </ul>
              )}
            </div>
          ))}
        </div>

        <div class="mt-8 rounded-xl2 bg-parchment border border-line p-5 text-xs text-muted leading-relaxed">
          <div class="font-semibold text-navy">FDA Disclaimer</div>
          These statements have not been evaluated by the Food and Drug Administration. This product is not intended to diagnose, treat, cure, or prevent any disease.
        </div>
      </div>

      <aside class="lg:col-span-4 space-y-6">
        <div class="rounded-xl2 bg-navy text-white border border-navy/10 shadow-soft overflow-hidden">
          <div class="p-6">
            <div class="text-xs font-semibold tracking-widest text-gold">PURCHASE STATUS</div>
            <div class="mt-2 font-serif text-2xl">Coming soon</div>
            <p class="mt-2 text-sm text-white/80 leading-relaxed">
              Shopify checkout is not live yet. Use Notify Me for early access.
            </p>
            <div class="mt-5 flex flex-wrap gap-3">
              <Button href="/shop" variant="gold" text="Purchase (Coming Soon)" />
              <Button href={buildMailto(f.cta)} variant="secondary" text="Notify Me" external={true} />
            </div>
          </div>
        </div>

        <div class="rounded-xl2 bg-card shadow-soft border border-line p-6">
          <div class="text-sm font-semibold text-navy">Educational note</div>
          <p class="mt-2 text-sm text-muted leading-relaxed">
            We publish dossiers and product pages using structure/function language only. No disease treatment claims. No medical advice.
          </p>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
