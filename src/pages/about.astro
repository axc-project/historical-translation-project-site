---
import Base from "../layouts/Base.astro";
import SectionTitle from "../components/SectionTitle.astro";
import { SITE } from "../data/site";
---
<Base title="About — Historical Translation Project™">
  <section class="mx-auto max-w-6xl px-5 py-14 sm:py-20">
    <SectionTitle
      eyebrow="About"
      title="A mission to translate global medical history into modern practice"
      subtitle="We research ancient remedies across global history and integrate them responsibly with modern scientific evidence, safety, and structure."
    />
    <div class="mt-12 grid lg:grid-cols-2 gap-10 items-start">
      <div class="rounded-2xl bg-white/70 ring-1 ring-black/5 shadow-card p-8">
        <div class="font-display text-2xl">Why this exists</div>
        <p class="mt-4 text-lg text-ink/75 leading-relaxed">
          Many historical traditions contain practical preventive insights—often expressed as diet, routine, and botanical use.
          We translate these into clean modern systems that are easy to follow and easy to expand over time.
        </p>
        <div class="mt-8 font-display text-2xl">First featured project</div>
        <p class="mt-4 text-lg text-ink/75 leading-relaxed">
          Our first publication focuses on Rambam (Maimonides) and medieval preventive medicine—paired with modern interpretations, dossiers, and formulation logic.
        </p>
        <div class="mt-6 flex flex-col sm:flex-row gap-3">
          <a href="/publications" class="no-underline hover:no-underline inline-flex justify-center rounded-md bg-gold text-ink font-semibold px-7 py-3 hover:bg-gold2 transition">
            View the book
          </a>
          <a href="/formulations" class="no-underline hover:no-underline inline-flex justify-center rounded-md bg-parchment2 ring-1 ring-black/10 px-7 py-3 hover:bg-parchment transition">
            Explore programs
          </a>
        </div>
      </div>
      <div class="rounded-2xl overflow-hidden ring-1 ring-black/10 shadow-soft">
        <img src="/images/brand-collage.jpg" alt="Brand collage" class="w-full h-[520px] object-cover" />
      </div>
    </div>

    <div class="mt-14 rounded-2xl bg-navy text-parchment p-8 sm:p-10 shadow-soft relative overflow-hidden grain">
      <div class="absolute inset-0 opacity-30"
           style="background-image: linear-gradient(90deg, rgba(11,26,42,.95), rgba(11,26,42,.65)), url('/images/hero-mountains.jpg'); background-size: cover; background-position: center;"></div>
      <div class="relative">
        <div class="font-display text-3xl text-gold2">What’s next</div>
        <p class="mt-4 text-xl text-parchment/85 leading-relaxed">
          Additional books, expanded research libraries, and new formulation programs. The site is intentionally modular so new projects can be added cleanly.
        </p>
        <div class="mt-6 text-parchment/75">
          Contact: <a class="text-parchment underline" href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </div>
      </div>
    </div>
  </section>
</Base>
