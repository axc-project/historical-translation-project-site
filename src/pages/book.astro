---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="The Book" description="About the book and the preventive medicine framework (Educational content only).">
  <section class="card" style="padding:22px">
    <div class="kicker">The Book</div>
    <h1 class="h1">Rambam’s Guide to Health</h1>
    <p style="max-width:70ch;margin-top:10px;color:rgba(11,18,32,.84)">
      A practical modern interpretation of medieval preventive medicine—focused on daily rhythm, diet, routine, temperament, and the foundations of resilient health.
    </p>
    <div class="hr"></div>
    <div class="grid cols-2">
      <div>
        <h2 class="h2">How to use this site</h2>
        <ul>
          <li>Start in the Research Library for dossiers</li>
          <li>Explore the formulas for ingredient transparency</li>
          <li>Use the Method page to understand our standards</li>
        </ul>
      </div>
      <div class="card" style="padding:16px">
        <div class="kicker">Next</div>
        <p class="small">When ready, add an excerpt PDF or a “Read sample” section here.</p>
        <a class="btn secondary" href="/research">Explore dossiers</a>
      </div>
    </div>
    <p class="small" style="margin-top:14px">Educational content only; not medical advice.</p>
  </section>
</BaseLayout>
