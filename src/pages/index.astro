---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import Button from "@components/Button.astro";
import Card from "@components/Card.astro";

const heroImage = "/images/hero-landscape.png";
---

<BaseLayout
  title="Historical Translation Project™"
  description="Research-driven botanical frameworks rooted in historical texts and aligned with contemporary safety standards."
>
  <!-- HERO -->
  <section class="hero">
    <div class="heroBg" style={`background-image:url(${heroImage});`}></div>
    <div class="heroOverlay"></div>
    <div class="heroFade"></div>

    <Container class="heroInner">
      <div class="heroKicker">Historical Translation Project™</div>

      <h1 class="heroTitle">
        Translating Classical Medicine Into<br />Structured Modern Systems
      </h1>

      <p class="heroSub">
        Research-driven botanical frameworks rooted in historical texts and aligned with contemporary safety standards.
      </p>

      <div class="heroActions">
        <Button href="/formulations" variant="primary">Explore Formulations</Button>
        <Button href="/publications" variant="secondary">View Publications</Button>
      </div>
    </Container>
  </section>

  <!-- HOME HUB -->
  <section class="parchment">
    <Container>
      <header class="hubHeader">
        <div class="hubKicker">Start Here</div>
        <h2 class="hubTitle">Browse the Project</h2>
        <p class="hubSub">
          Explore our formulation systems, foundational publications, and research notes—each translating historical doctrine into modern structure/function frameworks.*
        </p>
      </header>

      <div class="hubGrid">
        <!-- FORMULATIONS -->
        <Card variant="parchment" href="/formulations" ariaLabel="Go to formulations" class="hubCard">
          <div class="hubEyebrow">Formulations</div>
          <div class="hubCardTitle">Botanical Program Systems</div>
          <p class="hubCardText">
            A modular architecture: foundational cores first, with optional add-ons only when additional support is desired.*
          </p>
          <ul class="hubBullets">
            <li>Structured ingredient rationale</li>
            <li>Downloadable dossiers (PDF links)</li>
            <li>Purchase links (Shopify placeholders)</li>
          </ul>
          <div class="hubCTA">Explore Programs →</div>
        </Card>

        <!-- PUBLICATIONS -->
        <Card variant="parchment" href="/publications" ariaLabel="Go to publications" class="hubCard">
          <div class="hubEyebrow">Publications</div>
          <div class="hubCardTitle">Foundational Texts</div>
          <p class="hubCardText">
            Our work begins with texts. Each publication becomes a foundation for responsible translation into modern biological frameworks.
          </p>
          <ul class="hubBullets">
            <li>Amazon purchase placeholders</li>
            <li>Conceptual frameworks & excerpts</li>
            <li>Scalable library of future titles</li>
          </ul>
          <div class="hubCTA">View Books →</div>
        </Card>

        <!-- RESEARCH -->
        <Card variant="parchment" href="/research" ariaLabel="Go to research" class="hubCard hubCardWide">
          <div class="hubEyebrow">Research</div>
          <div class="hubCardTitle">Educational Translational Notes</div>
          <p class="hubCardText">
            We discuss disease categories as historical and biological context only—without product treatment claims.
            Our formulations are presented using conservative structure/function language and responsible safety framing.*
          </p>
          <div class="hubCTA">Read Research Notes →</div>
        </Card>
      </div>

      <p class="footnote">
        *Educational content only; not medical advice. These statements have not been evaluated by the Food and Drug Administration.
        This product is not intended to diagnose, treat, cure, or prevent any disease.
      </p>
    </Container>
  </section>
</BaseLayout>

<style>
  /* HERO */
  .hero { position: relative; overflow: hidden; background: #071523; }
  .heroBg { position:absolute; inset:0; background-size:cover; background-position:center; transform: scale(1.02); }
  .heroOverlay { position:absolute; inset:0; background: radial-gradient(900px 520px at 26% 18%, rgba(7,21,35,.18), rgba(7,21,35,.58)); }
  /* keep hero readable without washing it out */
  .heroFade { position:absolute; left:0; right:0; bottom:0; height: 22%; background: linear-gradient(to bottom, rgba(0,0,0,0), rgba(244,239,228,.55)); }
  .heroInner { position: relative; padding: 88px 0 96px; }
  .heroKicker { letter-spacing: .18em; text-transform: uppercase; font-size: 12px; color: rgba(255,255,255,.78); }
  .heroTitle { margin-top: 14px; font-family: ui-serif, Georgia, "Times New Roman", Times, serif; font-weight: 600; font-size: clamp(34px, 4.2vw, 56px); line-height: 1.04; color: #fff; }
  .heroSub { margin-top: 16px; max-width: 62ch; color: rgba(255,255,255,.88); font-size: 16px; line-height: 1.6; }
  .heroActions { margin-top: 22px; display:flex; gap:12px; flex-wrap: wrap; }

  /* HUB */
  .parchment {
    background:
      radial-gradient(1200px 700px at 28% 0%, rgba(212,175,55,.10), transparent 60%),
      linear-gradient(#f4efe4, #efe7d7);
    padding: 60px 0;
  }

  .hubHeader { max-width: 82ch; }
  .hubKicker { letter-spacing:.18em; text-transform:uppercase; font-size: 12px; color: rgba(7,21,35,.62); }
  .hubTitle { margin-top: 10px; font-family: ui-serif, Georgia, Times, serif; font-size: 34px; color: #071523; }
  .hubSub { margin-top: 10px; color: rgba(7,21,35,.78); line-height: 1.6; }

  .hubGrid {
    margin-top: 22px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .hubCard { padding: 22px; border-radius: 22px; }
  .hubEyebrow { letter-spacing:.16em; text-transform:uppercase; font-size: 12px; color: rgba(7,21,35,.60); }
  .hubCardTitle { margin-top: 8px; font-family: ui-serif, Georgia, Times, serif; font-size: 26px; color: #071523; }
  .hubCardText { margin-top: 10px; color: rgba(7,21,35,.78); line-height: 1.6; }

  .hubBullets { margin-top: 14px; padding-left: 18px; color: rgba(7,21,35,.86); line-height: 1.6; }
  .hubBullets li { margin-bottom: 6px; }

  .hubCTA { margin-top: 16px; font-weight: 800; color: #0b2a44; }

  .hubCardWide { grid-column: 1 / -1; }

  .footnote { margin-top: 22px; color: rgba(7,21,35,.62); font-size: 12px; line-height: 1.55; max-width: 95ch; }

  @media (max-width: 900px) {
    .hubGrid { grid-template-columns: 1fr; }
    .hubCardWide { grid-column: auto; }
  }
</style>
