---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Our Method — Historical Translation Project™';
const description = 'How we translate historical principles into modern educational dossiers and botanical formulations—responsibly and clearly.';
---
<BaseLayout title={title} description={description} canonical="/method">
  <section class="bg-parchment-50">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 rounded-full border border-slate-900/10 bg-white/70 px-4 py-2 text-xs text-slate-700 shadow-soft">Our Method</div>
        <h1 class="mt-6 text-4xl sm:text-5xl text-navy-950">Translate. Verify. Curate.</h1>
        <p class="mt-4 text-lg text-slate-700 leading-relaxed">
          We combine historical scholarship with modern evidence review to produce a clean, practical output: educational dossiers and
          formulations described in compliant structure/function language.
        </p>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        <div class="rounded-3xl border border-navy-950/10 bg-white/70 p-7 shadow-soft">
          <div class="text-xs uppercase tracking-wide text-slate-600">1</div>
          <h2 class="mt-2 text-2xl text-navy-950">Historical foundations</h2>
          <p class="mt-3 text-sm text-slate-700 leading-relaxed">Primary texts and cross-cultural traditions are summarized faithfully, with clear boundaries between quote, interpretation, and modern commentary.</p>
        </div>
        <div class="rounded-3xl border border-navy-950/10 bg-white/70 p-7 shadow-soft">
          <div class="text-xs uppercase tracking-wide text-slate-600">2</div>
          <h2 class="mt-2 text-2xl text-navy-950">Modern evidence signals</h2>
          <p class="mt-3 text-sm text-slate-700 leading-relaxed">We review reputable modern sources to identify plausible mechanisms and evidence strength—without overclaiming or implying medical treatment.</p>
        </div>
        <div class="rounded-3xl border border-navy-950/10 bg-white/70 p-7 shadow-soft">
          <div class="text-xs uppercase tracking-wide text-slate-600">3</div>
          <h2 class="mt-2 text-2xl text-navy-950">Manufacturing realism</h2>
          <p class="mt-3 text-sm text-slate-700 leading-relaxed">A formula isn’t “real” until it can be made cleanly, consistently, and compliantly—using ingredients with stable supply and standardized specs.</p>
        </div>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-2">
        <div class="rounded-3xl border border-slate-200 bg-white/70 p-8 shadow-soft">
          <h2 class="text-2xl text-navy-950">How we write product pages</h2>
          <ol class="mt-4 space-y-3 text-sm text-slate-700 list-decimal pl-5">
            <li><span class="font-semibold">Overview</span> — what it supports (structure/function language) and who it’s for.</li>
            <li><span class="font-semibold">Historical foundations</span> — the tradition and themes that justify the selection.</li>
            <li><span class="font-semibold">Modern overview</span> — what modern research suggests, at a high level.</li>
            <li><span class="font-semibold">Ingredient narrative</span> — each ingredient gets a “historical note” and “modern evidence signal.”</li>
            <li><span class="font-semibold">Curated add-ons</span> — optional modules only when additive; no redundancy.</li>
          </ol>
        </div>
        <div class="rounded-3xl bg-navy-950 text-white overflow-hidden shadow-soft relative">
          <div class="absolute inset-0 bg-navy-radial"></div>
          <div class="absolute inset-0 opacity-40 grain"></div>
          <div class="relative p-8">
            <h2 class="font-serif text-3xl">Designed to expand</h2>
            <p class="mt-3 text-white/75 leading-relaxed">
              The site architecture is modular: adding a new product means adding one data entry + one page file.
              Adding a new book means creating a new publication page and linking related dossiers.
            </p>
            <div class="mt-6 rounded-2xl bg-white/8 border border-white/10 p-5">
              <div class="font-semibold">Next steps</div>
              <ul class="mt-3 space-y-2 text-sm text-white/75">
                <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-gold-400"></span><span>Publish downloadable PDF dossiers for each formula</span></li>
                <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-gold-400"></span><span>Integrate Shopify for purchases and add-on bundles</span></li>
                <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-gold-400"></span><span>Expand the library as new books launch</span></li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
