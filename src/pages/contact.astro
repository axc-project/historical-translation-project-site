---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Contact • Historical Translation Project™">
  <section class="mx-auto max-w-6xl px-4 pt-10 pb-16">
    <div class="text-xs font-semibold tracking-widest text-gold">CONTACT</div>
    <h1 class="mt-2 font-serif text-4xl md:text-5xl text-navy">Get in touch</h1>
    <p class="mt-3 text-muted text-lg max-w-3xl">Partnerships, wholesale, press, and early access inquiries.</p>

    <div class="mt-10 rounded-xl2 bg-card shadow-soft border border-line p-6">
      <div class="text-sm font-semibold text-navy">Email</div>
      <p class="mt-2 text-sm text-muted">
        <a class="hover:text-gold" href="mailto:info@historicaltranslationproject.com">info@historicaltranslationproject.com</a>
      </p>
      <p class="mt-4 text-xs text-muted">Educational content only; not medical advice.</p>
    </div>
  </section>
</BaseLayout>
