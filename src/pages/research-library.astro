---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Research Library — Historical Translation Project™';
const description = 'A curated library connecting historical excerpts to modern evidence signals. (Initial scaffold—expandable as new dossiers are added.)';
---
<BaseLayout title={title} description={description} canonical="/research-library">
  <section class="bg-parchment-50">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 rounded-full border border-slate-900/10 bg-white/70 px-4 py-2 text-xs text-slate-700 shadow-soft">Research Library</div>
        <h1 class="mt-6 text-4xl sm:text-5xl text-navy-950">Curated evidence, organized for clarity</h1>
        <p class="mt-4 text-lg text-slate-700 leading-relaxed">
          This section is designed to scale: as we publish new books and new formulations, we add new dossiers and evidence summaries here.
          Each entry is written in plain language and links back to relevant product pages.
        </p>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        <div class="rounded-3xl border border-navy-950/10 bg-white/70 p-7 shadow-soft">
          <div class="text-xs uppercase tracking-wide text-slate-600">Theme</div>
          <h2 class="mt-2 text-2xl text-navy-950">Digestion & routine</h2>
          <p class="mt-3 text-sm text-slate-700">How meal structure, timing, and digestive comfort anchor preventive health across traditions.</p>
          <a class="mt-5 inline-flex text-sm font-semibold text-navy-950/80 hover:text-navy-950" href="/supplements/digestive-metabolic-core">Related formula →</a>
        </div>
        <div class="rounded-3xl border border-navy-950/10 bg-white/70 p-7 shadow-soft">
          <div class="text-xs uppercase tracking-wide text-slate-600">Theme</div>
          <h2 class="mt-2 text-2xl text-navy-950">Vitality & circulation</h2>
          <p class="mt-3 text-sm text-slate-700">Traditional vitality frameworks mapped to modern vascular and mitochondrial concepts.</p>
          <a class="mt-5 inline-flex text-sm font-semibold text-navy-950/80 hover:text-navy-950" href="/supplements/circulatory-vitality-core">Related formula →</a>
        </div>
        <div class="rounded-3xl border border-navy-950/10 bg-white/70 p-7 shadow-soft">
          <div class="text-xs uppercase tracking-wide text-slate-600">Theme</div>
          <h2 class="mt-2 text-2xl text-navy-950">Urinary comfort</h2>
          <p class="mt-3 text-sm text-slate-700">Hydration habits, comfort strategies, and traditionally referenced botanicals.</p>
          <a class="mt-5 inline-flex text-sm font-semibold text-navy-950/80 hover:text-navy-950" href="/supplements/urinary-flow-support">Related module →</a>
        </div>
      </div>

      <div class="mt-10 rounded-3xl bg-navy-950 text-white overflow-hidden shadow-soft relative">
        <div class="absolute inset-0 bg-navy-radial"></div>
        <div class="absolute inset-0 opacity-40 grain"></div>
        <div class="relative p-8 sm:p-10">
          <h2 class="font-serif text-3xl">Want the full dossiers?</h2>
          <p class="mt-3 text-white/75 max-w-2xl">We will publish downloadable PDFs for each formulation and theme. If you want the first release, join the list.</p>
          <div class="mt-6 flex flex-col sm:flex-row gap-3">
            <a class="btn-gold inline-flex items-center justify-center rounded-full bg-gold-400 px-6 py-3 text-sm font-semibold text-navy-950 shadow-glow hover:bg-gold-200" href="/dossiers">Dossiers page</a>
            <a class="inline-flex items-center justify-center rounded-full border border-white/15 bg-white/5 px-6 py-3 text-sm font-semibold text-white hover:bg-white/10" href="mailto:info@axellaresearch.com?subject=HTP%20Dossier%20Updates">Email for updates</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
