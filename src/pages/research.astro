---
import Base from "../layouts/Base.astro";
import SectionTitle from "../components/SectionTitle.astro";
---
<Base title="Research — Historical Translation Project™">
  <section class="mx-auto max-w-6xl px-5 py-14 sm:py-20">
    <SectionTitle
      eyebrow="Research"
      title="Historical foundations → structured modern systems"
      subtitle="We study classical preventive medicine across global traditions, extract practical principles, then translate them into modern structure/function education and formulation logic."
    />
    <div class="mt-12 grid lg:grid-cols-2 gap-10 items-start">
      <div class="rounded-2xl bg-white/70 ring-1 ring-black/5 shadow-card p-8">
        <div class="font-display text-2xl">How we work</div>
        <ol class="mt-4 space-y-3 text-lg text-ink/75 list-decimal list-inside">
          <li><span class="font-semibold">Source</span>: primary texts, authoritative translations, and commentaries.</li>
          <li><span class="font-semibold">Extract</span>: practical principles and ingredient mentions (no medical claims).</li>
          <li><span class="font-semibold">Cross‑map</span>: safety and modern evidence signals.</li>
          <li><span class="font-semibold">Translate</span>: structured education + clean formulation logic.</li>
          <li><span class="font-semibold">Publish</span>: dossiers, references, and transparent program pages.</li>
        </ol>
      </div>
      <div>
        <div class="rounded-2xl overflow-hidden ring-1 ring-black/10 shadow-soft">
          <img src="/images/open-book.jpg" alt="Research imagery" class="w-full h-[360px] object-cover" />
        </div>
        <p class="mt-6 text-lg text-ink/70 leading-relaxed">
          Our goal is to stay true to historical foundations while presenting conservative modern interpretations designed for everyday routines.
        </p>
      </div>
    </div>
  </section>
</Base>
