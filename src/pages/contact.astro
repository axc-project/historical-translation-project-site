---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact" description="Contact Historical Translation Project™.">
  <section class="card" style="padding:22px">
    <div class="kicker">Contact</div>
    <h1 class="h1">Get in touch</h1>
    <p class="small" style="max-width:80ch;margin-top:10px">
      Replace the email address and/or connect a form provider later (Formspree, Google Forms, etc.).
    </p>

    <div class="hr"></div>

    <div class="grid cols-2">
      <div class="card" style="padding:16px">
        <div class="kicker">Email</div>
        <p style="margin-top:10px">
          <a class="btn" href="mailto:info@example.com">info@example.com</a>
        </p>
        <p class="small">Update this address in <code>src/components/NotifyForm.astro</code> and this page.</p>
      </div>

      <div class="card" style="padding:16px">
        <div class="kicker">Press / Partnerships</div>
        <p class="small" style="margin-top:10px">
          For collaboration inquiries, include your goals and timeline. Educational content only; not medical advice.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
