---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Button from "../../components/Button.astro";
import { formulations } from "../../data/formulations.js";
import { buildMailto } from "../../utils/cta.js";
---
<BaseLayout title="Formulations • Historical Translation Project™">
  <section class="mx-auto max-w-6xl px-4 pt-10 pb-16">
    <div class="text-xs font-semibold tracking-widest text-gold">FORMULATIONS</div>
    <h1 class="mt-2 font-serif text-4xl md:text-5xl text-navy">Two cores plus targeted add‑ons</h1>
    <p class="mt-3 text-muted text-lg max-w-3xl">
      Shopify checkout is not live yet. Purchase buttons take you to a <span class="font-semibold">Coming Soon</span> placeholder.
      You can request early access via “Notify Me.”
    </p>

    <div class="mt-10 grid md:grid-cols-2 gap-6">
      {formulations.map(f => (
        <div class="rounded-xl2 bg-card shadow-soft border border-line p-6">
          <div class="flex items-start justify-between gap-4">
            <div>
              <div class="text-xs font-semibold tracking-widest text-gold">{f.tier} FORMULA</div>
              <div class="mt-2 font-serif text-2xl text-navy">{f.name}</div>
              <div class="mt-2 text-sm text-muted">{f.subtitle}</div>
            </div>
            <a href="/shop" class="text-xs font-semibold text-navy/70 hover:text-gold">Purchase →</a>
          </div>

          <p class="mt-4 text-sm text-muted leading-relaxed">{f.overview}</p>

          <div class="mt-5 flex flex-wrap gap-3">
            <Button href={`/formulations/${f.slug}`} variant="secondary" text="View Details" />
            <Button href={f.purchase.href} variant="gold" text={f.purchase.label} />
            <Button href={buildMailto(f.cta)} variant="secondary" text="Notify Me" external={true} />
          </div>

          <div class="mt-4 text-xs text-muted">
            Educational content only; not medical advice.
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
