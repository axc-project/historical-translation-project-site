---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { formulas } from "../../data/formulas";

export function getStaticPaths() {
  return formulas.map((f) => ({ params: { slug: f.slug } }));
}

const { slug } = Astro.params;
const f = formulas.find((x) => x.slug === slug);
if (!f) throw new Error("Formula not found");
---
<BaseLayout title={`${f.title} • Historical Translation Project™`}>
  <Header />
  <main class="mx-auto max-w-6xl px-4 py-12">
    <div class="grid gap-8 lg:grid-cols-2 lg:items-start">
      <div class="card overflow-hidden">
        <img src={f.image} alt={f.title} class="w-full h-auto" />
      </div>
      <div>
        <div class="kicker">Formulation</div>
        <h1 class="mt-3 h-serif text-4xl sm:text-5xl">{f.title}</h1>
        <p class="mt-5 text-ink-900/70 leading-relaxed">
          {f.excerpt}
        </p>
        <div class="mt-7 flex gap-3 flex-col sm:flex-row">
          <a href="/shop" class="btn-primary">Purchase</a>
          <a href="/research" class="btn-ghost">View Research</a>
        </div>
        <p class="mt-4 text-xs text-ink-900/55">
          These statements have not been evaluated by the Food and Drug Administration.
          This product is not intended to diagnose, treat, cure, or prevent any disease.
        </p>
      </div>
    </div>

    <div class="mt-12 grid gap-8 lg:grid-cols-[1fr,320px]">
      <article class="card p-8">
        <div class="prose max-w-none">
          {f.body.map((p) => (<p class="mt-4 first:mt-0 text-ink-900/80 leading-relaxed">{p}</p>))}
        </div>
      </article>

      <aside class="space-y-6">
        <div class="card p-6">
          <div class="kicker">Add-ons</div>
          <div class="mt-2 h-serif text-xl">Optional complements</div>
          <p class="mt-3 text-sm text-ink-900/70 leading-relaxed">
            When add-ons are available, we curate options that avoid duplication with core formulas and support a low-pill routine.
            Purchase links will appear here once the Shopify catalog is connected.
          </p>
        </div>
        <div class="card p-6">
          <div class="kicker">Downloads</div>
          <div class="mt-2 h-serif text-xl">Formula dossier</div>
          <p class="mt-3 text-sm text-ink-900/70 leading-relaxed">
            A clinician-ready dossier (historical lineage + modern evidence + ingredient rationale) will be published for this program.
          </p>
          <a href="/research" class="mt-4 inline-flex text-sm font-semibold text-ink-900 hover:underline">See research →</a>
        </div>
      </aside>
    </div>

    <div class="mt-12">
      <a href="/formulations" class="text-sm font-semibold text-ink-900/70 hover:text-ink-900">← Back to all formulations</a>
    </div>
  </main>
  <Footer />
</BaseLayout>
