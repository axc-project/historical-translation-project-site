---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Privacy Policy" description="Privacy policy placeholder. Replace with counsel-reviewed text before launch.">
  <section class="card" style="padding:22px">
    <div class="kicker">Legal</div>
    <h1 class="h1">Privacy Policy</h1>
    <p class="small">Placeholder. Replace with your final policy before collecting personal data.</p>

    <div class="hr"></div>
    <h2 class="h2">What we collect</h2>
    <ul class="small">
      <li>Contact information you voluntarily submit (e.g., email for notifications)</li>
      <li>Basic analytics (if enabled)</li>
    </ul>

    <h2 class="h2" style="margin-top:14px">How we use it</h2>
    <ul class="small">
      <li>To notify you about new dossiers or product availability</li>
      <li>To improve site performance and content</li>
    </ul>
  </section>
</BaseLayout>
