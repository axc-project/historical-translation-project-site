---
import BaseLayout from '../layouts/BaseLayout.astro';
import research from '../data/research.json';
import products from '../data/products.json';

const productById = Object.fromEntries(products.map(p => [p.id, p]));
---
<BaseLayout title="Research Library" description="Educational dossiers with historical excerpts + modern references.">
  <section class="card" style="padding:22px">
    <div class="kicker">Research Library</div>
    <h1 class="h1">Downloadable dossiers</h1>
    <p style="max-width:70ch;margin-top:10px;color:rgba(11,18,32,.84)">
      Evidence-forward summaries designed for education and transparency. Each dossier is educational content only and not medical advice.
    </p>
  </section>

  <section style="margin-top:16px" class="grid">
    {research.map(r => {
      const p = productById[r.relatedProductId];
      return (
        <article class="card" style="padding:16px">
          <div style="display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;align-items:center">
            <div class="badge">{r.category}</div>
            <div class="small">{r.date}</div>
          </div>
          <h2 class="h2" style="margin-top:10px">{r.title}</h2>
          <p class="small" style="max-width:95ch;margin-top:6px">{r.summary}</p>
          <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:12px">
            {r.downloadPath ? (
              <a class="btn" href={r.downloadPath} target="_blank" rel="noopener">Download PDF</a>
            ) : (
              <span class="btn disabled" aria-disabled="true">Coming soon</span>
            )}
            <a class="btn secondary" href={`/supplements/${p.id}`}>View formula</a>
          </div>
        </article>
      );
    })}
  </section>
</BaseLayout>
