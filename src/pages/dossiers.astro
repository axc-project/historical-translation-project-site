---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Download Dossiers — Historical Translation Project™';
const description = 'Download printable PDF dossiers for each formulation. (Initial placeholders included; full dossiers will be expanded.)';

const dossiers = [
  {
    title: 'Digestive Metabolic Core™ — Dossier',
    file: '/dossiers/digestive-metabolic-core-dossier.pdf',
    note: 'Foundational digestive + metabolic rhythm support (educational summary).'
  },
  {
    title: 'Circulatory Vitality Core™ — Dossier',
    file: '/dossiers/circulatory-vitality-core-dossier.pdf',
    note: 'Foundational circulation + vitality support (educational summary).'
  },
  {
    title: 'Urinary Flow Support™ — Dossier',
    file: '/dossiers/urinary-flow-support-dossier.pdf',
    note: 'Targeted module for urinary comfort and flow (educational summary).'
  }
];
---
<BaseLayout title={title} description={description} canonical="/dossiers">
  <section class="bg-parchment-50">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 rounded-full border border-slate-900/10 bg-white/70 px-4 py-2 text-xs text-slate-700 shadow-soft">Downloads</div>
        <h1 class="mt-6 text-4xl sm:text-5xl text-navy-950">Dossiers</h1>
        <p class="mt-4 text-lg text-slate-700 leading-relaxed">
          Each dossier is designed for clarity: historical foundations, modern evidence signals, and clean ingredient narratives.
          This page is built to scale as more products and books are added.
        </p>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {dossiers.map((d) => (
          <article class="rounded-3xl border border-navy-950/10 bg-white/70 p-7 shadow-soft">
            <h2 class="text-2xl text-navy-950">{d.title}</h2>
            <p class="mt-3 text-sm text-slate-700">{d.note}</p>
            <div class="mt-6 flex items-center gap-3">
              <a class="btn-gold inline-flex items-center justify-center rounded-full bg-gold-400 px-5 py-2 text-sm font-semibold text-navy-950 shadow-glow hover:bg-gold-200" href={d.file} target="_blank" rel="noreferrer">Download PDF</a>
              <a class="text-sm font-semibold text-navy-950/80 hover:text-navy-950" href="/supplements">View products</a>
            </div>
            <p class="mt-4 text-xs text-slate-600">Note: these are placeholder PDFs in this build; we’ll replace with full dossiers.</p>
          </article>
        ))}
      </div>

      <div class="mt-10 rounded-3xl bg-navy-950 text-white overflow-hidden shadow-soft relative">
        <div class="absolute inset-0 bg-navy-radial"></div>
        <div class="absolute inset-0 opacity-40 grain"></div>
        <div class="relative p-8 sm:p-10">
          <h2 class="font-serif text-3xl">Want the full version first?</h2>
          <p class="mt-3 text-white/75 max-w-2xl">Email us and we’ll send you the updated dossier package as soon as the expanded PDFs are published.</p>
          <a class="mt-6 inline-flex items-center justify-center rounded-full bg-gold-400 px-6 py-3 text-sm font-semibold text-navy-950 shadow-glow hover:bg-gold-200" href="mailto:info@axellaresearch.com?subject=HTP%20Dossier%20Request">Request the dossier pack</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
