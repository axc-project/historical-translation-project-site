---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import Card from "@components/Card.astro";
import Button from "@components/Button.astro";
import SectionHeading from "@components/SectionHeading.astro";
import { formulas } from "@data/formulas";
---
<BaseLayout title="Formulations — Historical Translation Project™">
  <Container class="pt-14">
    <SectionHeading
      title="Formulations"
      lede="Foundational cores first, with optional add-ons only when additional support is desired.*"
    />

    <div class="grid gap-6 md:grid-cols-2">
      {formulas.map((f) => (
        <Card class="p-7">
          {f.bottleImage && (
            <div class="mb-5 flex justify-end">
              <div class="h-24 w-24 rounded-2xl border border-gold-500/15 bg-white/5 p-2">
                <img
                  src={f.bottleImage}
                  alt=""
                  class="h-full w-full object-contain brightness-110 contrast-110"
                  loading="lazy"
                />
              </div>
            </div>
          )}
          <div class="text-[11px] uppercase tracking-[0.22em] text-gold-450/90">
            {f.category}
          </div>
          <h2 class="mt-3 font-serif text-2xl text-white">{f.name}</h2>
          <p class="mt-3 text-white/75 leading-relaxed">{f.heroTagline}</p>

          <div class="mt-6 flex flex-wrap gap-3">
            <Button href={`/formulations/${f.slug}`} variant="primary">View Program</Button>
            <Button
              href={f.dossierUrl && f.dossierUrl.length ? f.dossierUrl : "#"}
              variant="secondary"
              class={f.dossierUrl && f.dossierUrl.length ? "" : "pointer-events-none opacity-60"}
            >
              Download Dossier
            </Button>
            <Button
              href={f.shopUrl && f.shopUrl.length ? f.shopUrl : "#"}
              variant="secondary"
              class={f.shopUrl && f.shopUrl.length ? "" : "pointer-events-none opacity-60"}
            >
              Purchase
            </Button>
          </div>
        </Card>
      ))}
    </div>
  </Container>
</BaseLayout>
