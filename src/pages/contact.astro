---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Contact — Historical Translation Project™';
const description = 'Contact Historical Translation Project™. For partnerships, questions, or product updates, email info@axellaresearch.com.';
---
<BaseLayout title={title} description={description} canonical="/contact">
  <section class="bg-parchment-50">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <div class="grid gap-10 lg:grid-cols-12">
        <div class="lg:col-span-6">
          <div class="inline-flex items-center gap-2 rounded-full border border-slate-900/10 bg-white/70 px-4 py-2 text-xs text-slate-700 shadow-soft">Contact</div>
          <h1 class="mt-6 text-4xl sm:text-5xl text-navy-950">Get in touch</h1>
          <p class="mt-4 text-lg text-slate-700 leading-relaxed">
            For questions, partnerships, wholesale/white‑label discussions, or launch updates—reach out here.
          </p>

          <div class="mt-8 rounded-3xl bg-navy-950 text-white overflow-hidden shadow-soft relative">
            <div class="absolute inset-0 bg-navy-radial"></div>
            <div class="absolute inset-0 opacity-40 grain"></div>
            <div class="relative p-8">
              <div class="text-gold-200 text-xs uppercase tracking-wide">Primary email</div>
              <a class="mt-2 block font-serif text-2xl hover:underline" href="mailto:info@axellaresearch.com">info@axellaresearch.com</a>
              <p class="mt-3 text-white/75 text-sm">We aim to respond within 1–2 business days.</p>
            </div>
          </div>

          <div class="mt-6 rounded-3xl border border-slate-200 bg-white/70 p-8 shadow-soft">
            <h2 class="text-2xl text-navy-950">Common requests</h2>
            <ul class="mt-4 space-y-2 text-sm text-slate-700">
              <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-gold-400"></span><span>Notify me when Shopify checkout is live</span></li>
              <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-gold-400"></span><span>Request the full dossiers as PDFs</span></li>
              <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-gold-400"></span><span>Wholesale / white‑label partnerships</span></li>
              <li class="flex gap-2"><span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-gold-400"></span><span>Press / podcast / speaking inquiries</span></li>
            </ul>
          </div>
        </div>

        <div class="lg:col-span-6">
          <div class="rounded-3xl border border-navy-950/10 bg-white/70 p-8 shadow-soft">
            <h2 class="text-2xl text-navy-950">Send a message</h2>
            <p class="mt-2 text-sm text-slate-700">This form opens your email client with the message content.</p>

            <form class="mt-6 space-y-4" action="mailto:info@axellaresearch.com" method="post" enctype="text/plain">
              <div>
                <label class="block text-sm font-semibold text-slate-800">Your email</label>
                <input class="mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm" type="email" name="email" required placeholder="you@example.com" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-slate-800">Subject</label>
                <input class="mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm" type="text" name="subject" required placeholder="Inquiry / Updates / Wholesale" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-slate-800">Message</label>
                <textarea class="mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm" name="message" rows="7" required placeholder="How can we help?"></textarea>
              </div>
              <button class="btn-gold w-full rounded-full bg-gold-400 px-6 py-3 text-sm font-semibold text-navy-950 shadow-glow hover:bg-gold-200 transition" type="submit">Open email draft</button>
            </form>

            <p class="mt-4 text-xs text-slate-600">We’ll integrate a hosted form later (e.g., Shopify/Forms/CRM).</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
