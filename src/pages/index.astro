---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Historical Translation Project™">
  <Header />

  <main>
    <!-- Hero (full-bleed background with faded image + text overlay) -->
    <section class="relative isolate overflow-hidden bg-navy-900">
      <img
        src="/images/brand/brand-collage.jpg"
        alt=""
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 h-full w-full object-cover opacity-35"
        loading="eager"
      />
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(215,181,109,0.30),transparent_55%)]"></div>
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-navy-900/55 via-navy-900/30 to-parchment-100"></div>

      <div class="relative mx-auto max-w-6xl px-4 pt-16 pb-14 sm:pt-20 sm:pb-16">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 rounded-full bg-white/10 ring-1 ring-white/15 px-4 py-2 shadow-soft">
            <span class="h-2 w-2 rounded-full bg-gold-500"></span>
            <span class="text-sm text-white/85">Historical foundations + modern evidence</span>
          </div>

          <h1 class="mt-8 h-serif text-5xl sm:text-6xl leading-[0.95] text-white">
            A research-first approach to everyday botanical wellness.
          </h1>

          <p class="mt-6 text-lg leading-relaxed text-white/80 max-w-2xl">
            We translate preventive principles from across global medical history into modern, evidence-forward educational dossiers—
            and thoughtfully designed botanical formulations framed in compliant structure/function language.
          </p>

          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            <a href="/formulations" class="btn-primary">Explore Formulations</a>
            <a href="/research" class="btn-ghost">Explore Research</a>
          </div>

          <p class="mt-4 text-xs text-white/70">
            Educational content only; not medical advice. Supplements are not intended to diagnose, treat, cure, or prevent disease.
          </p>
        </div>
      </div>
    </section>

    <!-- Section cards -->
    <section class="mx-auto max-w-6xl px-4 py-14">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        <a href="/research" class="card-dark p-7 hover:translate-y-[-2px] transition">
          <div class="kicker kicker-on-dark">Research</div>
          <div class="mt-2 h-serif text-2xl text-white">Translational analyses</div>
          <p class="mt-3 text-white/80">
            Historical textual analysis, modern evidence signals, and pathway-level interpretation—written for clinicians and curious patients.
          </p>
        </a>

        <a href="/publications" class="card-dark p-7 hover:translate-y-[-2px] transition">
          <div class="kicker kicker-on-dark">Publications</div>
          <div class="mt-2 h-serif text-2xl text-white">Foundational books</div>
          <p class="mt-3 text-white/80">
            The publications that anchor our mission and inform every formulation—presented with clear summaries and purchase links.
          </p>
        </a>

        <a href="/formulations" class="card-dark p-7 hover:translate-y-[-2px] transition">
          <div class="kicker kicker-on-dark">Formulations</div>
          <div class="mt-2 h-serif text-2xl text-white">Structured programs</div>
          <p class="mt-3 text-white/80">
            Our formulations bridge historically proven methods with modern-day data and studies to create targeted support supplements.
          </p>
        </a>

        <a href="/method" class="card-dark p-7 hover:translate-y-[-2px] transition">
          <div class="kicker kicker-on-dark">Method</div>
          <div class="mt-2 h-serif text-2xl text-white">Bridge old + new</div>
          <p class="mt-3 text-white/80">
            A disciplined process that ties each ingredient to historical lineage, modern evidence, and safety-first stacking logic.
          </p>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
