---
const items = [
  { href: "/research", label: "Research" },
  { href: "/publications", label: "Publications" },
  { href: "/formulations", label: "Formulations" },
  { href: "/method", label: "Method" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---
<nav class="hidden lg:flex items-center gap-8 text-parchment/90 font-serif text-lg">
  {items.map((it) => (
    <a href={it.href} class="hover:text-gold2 transition-colors">{it.label}</a>
  ))}
</nav>

<div class="lg:hidden">
  <button id="menuBtn" class="w-12 h-12 rounded-full bg-white/10 ring-1 ring-white/15 flex items-center justify-center hover:bg-white/15 transition" aria-label="Open menu">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
      <path d="M4 7h16M4 12h16M4 17h16" stroke="rgba(255,255,255,.92)" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>
</div>

<script is:inline>
  const btn = document.getElementById('menuBtn');
  const panel = document.getElementById('mobileNav');
  const closeBtn = document.getElementById('closeNav');
  const open = () => panel?.classList.remove('hidden');
  const close = () => panel?.classList.add('hidden');
  btn?.addEventListener('click', open);
  closeBtn?.addEventListener('click', close);
  panel?.addEventListener('click', (e) => { if(e.target === panel) close(); });
</script>
