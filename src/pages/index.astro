---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import products from '../data/products.json';
import research from '../data/research.json';

const featuredProducts = products.slice(0,3);
const featuredResearch = research.slice(0,3);
---
<BaseLayout title="Home" description="Historical foundations + modern evidence. Educational content only; not medical advice.">
  <section class="card" style="padding:22px;overflow:hidden">
    <div class="grid cols-2" style="align-items:center">
      <div>
        <div class="kicker">Historical foundations + modern evidence</div>
        <h1 class="h1">A research-first approach to everyday botanical wellness.</h1>
        <p style="max-width:62ch;margin:12px 0 18px;color:rgba(11,18,32,.84)">
          Historical Translation Project™ translates medieval preventive principles into modern, evidence-forward educational dossiers and thoughtfully designed botanical formulas—framed in compliant structure/function language.
        </p>
        <div style="display:flex;gap:10px;flex-wrap:wrap">
          <a class="btn" href="/research">Browse dossiers</a>
          <a class="btn secondary" href="/supplements">Explore supplements</a>
          <a class="btn ghost" href="/book">About the book</a>
        </div>
        <p class="small" style="margin-top:14px">
          Educational content only; not medical advice. Supplements are not intended to diagnose, treat, cure, or prevent disease.
        </p>
      </div>
      <div class="card" style="padding:18px;background:linear-gradient(135deg, rgba(11,27,58,.94), rgba(15,37,80,.70));color:#fff;border:1px solid rgba(227,198,106,.25)">
        <div class="kicker" style="color:rgba(227,198,106,.92)">What you’ll find here</div>
        <ul style="margin:12px 0 0">
          <li>Downloadable dossiers (historical excerpts + modern references)</li>
          <li>Clear, conservative structure/function language</li>
          <li>Formulas designed for routine support</li>
          <li>Quality-first manufacturing notes</li>
        </ul>
      </div>
    </div>
  </section>

  <section style="margin-top:26px">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:12px;flex-wrap:wrap">
      <div>
        <div class="kicker">Supplements</div>
        <h2 class="h2">Three formulas in development</h2>
      </div>
      <a class="btn secondary" href="/supplements">View all</a>
    </div>
    <div class="grid cols-3" style="margin-top:14px">
      {featuredProducts.map(p => <ProductCard p={p} />)}
    </div>
  </section>

  <section style="margin-top:26px">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:12px;flex-wrap:wrap">
      <div>
        <div class="kicker">Research library</div>
        <h2 class="h2">Download educational dossiers</h2>
      </div>
      <a class="btn secondary" href="/research">Browse all</a>
    </div>

    <div class="grid cols-3" style="margin-top:14px">
      {featuredResearch.map(r => (
        <article class="card" style="padding:16px">
          <div class="badge">{r.category}</div>
          <h3 class="h3" style="margin-top:10px">{r.title}</h3>
          <p class="small" style="margin:8px 0 12px">{r.summary}</p>
          <div style="display:flex;gap:10px;flex-wrap:wrap">
            {r.downloadPath ? (
              <a class="btn" href={r.downloadPath} target="_blank" rel="noopener">Download PDF</a>
            ) : (
              <span class="btn disabled" aria-disabled="true">Coming soon</span>
            )}
            <a class="btn ghost" href={`/supplements/${r.relatedProductId}`}>Related formula</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
