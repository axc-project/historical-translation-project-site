---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import { formulations } from "../data/formulations.js";
import { buildMailto } from "../utils/cta.js";
const cores = formulations.filter(f=>f.tier==="Core");
---

<BaseLayout title="Historical Translation Project™" description="Ancient preventive wisdom, translated for modern life.">
  <section class="hero-bg relative overflow-hidden">
    <div class="absolute inset-0 hero-banner opacity-95"></div>
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-32 -left-40 w-[720px] h-[720px] rounded-full bg-gold/10 blur-3xl" style="animation: shimmer 12s ease-in-out infinite;"></div>
      <div class="absolute -bottom-40 -right-48 w-[820px] h-[820px] rounded-full bg-navy/10 blur-3xl" style="animation: shimmer 14s ease-in-out infinite;"></div>
    </div>

    <div class="relative mx-auto max-w-6xl px-4 pt-14 pb-12">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-7">
          <div class="inline-flex items-center gap-2 rounded-full border border-navy/10 glass px-4 py-2 text-xs font-semibold text-navy soft-ring">
            <span class="h-2 w-2 rounded-full bg-gold"></span>
            Historical foundations • Modern evidence • Compliance‑first
          </div>

          <h1 class="mt-6 font-serif text-4xl md:text-6xl text-parchment leading-tight drop-shadow-sm">
            Ancient preventive wisdom,
            <span class="text-gold">translated</span> for modern life.
          </h1>

          <p class="mt-5 text-lg text-parchment/85 max-w-2xl leading-relaxed">
            We research historical medical systems across cultures and integrate them with reputable modern sources—publishing premium consumer dossiers and designing a modular system of core formulas plus targeted add‑ons.
          </p>

          <div class="mt-7 flex flex-col sm:flex-row gap-3">
            <Button href="/formulations" text="Explore Formulas" />
            <Button href="/shop" variant="gold" text="Purchase" />
            <Button href="/book" variant="secondary" text="View the Book" />
            <Button href="/projects/rambam" variant="secondary" text="Project 01: Rambam" />
          </div>

          <div class="mt-6 text-xs text-parchment/70 leading-relaxed max-w-2xl">
            Educational content only; not medical advice. These statements have not been evaluated by the FDA.
            Products are not intended to diagnose, treat, cure, or prevent any disease.
          </div>
        </div>

        <!-- Editorial collage -->
        <div class="lg:col-span-5">
          <div class="relative">
            <div class="absolute -inset-4 rounded-[28px] bg-gold/10 blur-2xl"></div>

            <div class="relative grid grid-cols-12 gap-4">
              <div class="col-span-7 rounded-xl2 overflow-hidden glow-ring border border-white/25" style="animation: floaty 9s ease-in-out infinite;">
                <img src="/images/book-cover-hero.jpg" alt="Rambam’s Guide to Health cover" class="w-full h-full object-cover" loading="lazy"/>
              </div>

              <div class="col-span-5 grid gap-4">
                <div class="rounded-xl2 overflow-hidden soft-ring border border-white/25 glass">
                  <div class="p-4">
                    <div class="text-xs font-semibold tracking-widest text-gold">FEATURED BOOK</div>
                    <div class="mt-2 font-serif text-xl text-navy">Rambam’s Guide to Health</div>
                    <p class="mt-2 text-xs text-muted leading-relaxed">
                      A practical modern interpretation of medieval preventive medicine—our inaugural publication.
                    </p>
                    <div class="mt-3 flex flex-wrap gap-2">
                      <Button href="https://www.amazon.com/dp/B0GPNWH877" variant="gold" text="Purchase" external={true} />
                      <Button href="/book" variant="secondary" text="Details" />
                    </div>
                  </div>
                </div>

                <div class="rounded-xl2 overflow-hidden soft-ring border border-white/25 bg-white">
                  <img src="/images/botanical-lineart.svg" alt="Botanical illustration" class="w-full h-[190px] object-cover" loading="lazy"/>
                </div>
              </div>

              <div class="col-span-12 rounded-xl2 glass soft-ring border border-white/25 p-5">
                <div class="grid sm:grid-cols-3 gap-4">
                  {[
                    { icon:"/images/icons/scroll.svg", t:"Primary texts", d:"Historical sources translated in context" },
                    { icon:"/images/icons/shield.svg", t:"Safety-first", d:"Cautions and interactions disclosed" },
                    { icon:"/images/icons/leaf.svg", t:"Botanical rigor", d:"Modern ID + reputable references" },
                  ].map(x => (
                    <div class="flex items-start gap-3">
                      <div class="h-10 w-10 rounded-xl2 bg-navy text-parchment flex items-center justify-center">
                        <img src={x.icon} alt="" class="h-6 w-6" />
                      </div>
                      <div>
                        <div class="text-sm font-semibold text-navy">{x.t}</div>
                        <div class="text-xs text-muted mt-1 leading-relaxed">{x.d}</div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Cores strip -->
      <div class="mt-10 grid md:grid-cols-2 gap-6">
        {cores.map(c => (
          <div class="rounded-xl2 bg-white/85 border border-white/25 soft-ring overflow-hidden">
            <div class="p-6">
              <div class="text-xs font-semibold tracking-widest text-gold">{c.tier} FORMULA</div>
              <div class="mt-2 font-serif text-2xl text-navy">{c.name}</div>
              <div class="mt-1 text-sm text-muted">{c.subtitle}</div>
              <div class="mt-4 flex flex-wrap gap-3">
                <Button href={`/formulations/${c.slug}`} variant="secondary" text="View Details" />
                <Button href={buildMailto(c.cta)} variant="gold" text="Notify Me" external={true} />
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-14 pt-8">
    <div class="rounded-xl2 bg-navy text-white border border-navy/10 shadow-soft overflow-hidden relative">
      <div class="absolute inset-0 opacity-30" style="background-image: radial-gradient(circle at 20% 20%, rgba(199,164,74,0.55), transparent 55%), radial-gradient(circle at 80% 50%, rgba(255,255,255,0.18), transparent 55%);"></div>
      <div class="relative p-8 md:p-10 grid md:grid-cols-3 gap-8">
        <div>
          <div class="text-xs font-semibold tracking-widest text-gold">OUR PROMISE</div>
          <div class="mt-2 font-serif text-3xl leading-tight">Premium clarity, not marketing hype.</div>
          <p class="mt-3 text-white/80 text-sm leading-relaxed">
            We avoid disease claims. We cite reputable sources. We translate history responsibly.
          </p>
        </div>
        <div class="md:col-span-2 grid sm:grid-cols-2 gap-4">
          {[
            {t:"Historically grounded", d:"Mediterranean + global traditions, contextualized."},
            {t:"Modernly constrained", d:"Safety-first, compliant, no medical advice."},
            {t:"Premium presentation", d:"Designed for trust and editorial quality."},
            {t:"Built to stack", d:"Two cores + add-ons to minimize pills."},
          ].map(c => (
            <div class="rounded-xl2 bg-white/5 border border-white/10 p-5">
              <div class="font-semibold">{c.t}</div>
              <div class="mt-2 text-sm text-white/80">{c.d}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
